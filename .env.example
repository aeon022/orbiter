# Orbiter — Environment Variables
# Copy to .env and fill in your values

# Pod file path (relative to project root)
ORBITER_POD_PATH=./content.pod

# Admin credentials (Phase 2)
ORBITER_ADMIN_USER=admin
ORBITER_ADMIN_PASSWORD=

# Deploy webhook (Phase 3)
ORBITER_DEPLOY_WEBHOOK=

# Site config
PUBLIC_SITE_URL=http://localhost:8080
