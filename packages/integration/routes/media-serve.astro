---
export const prerender = false;
/**
 * /orbiter/media/[id] — serves a media BLOB from the .pod file.
 * Public — no auth required. Used in Astro pages: <img src="/orbiter/media/{uuid}">
 */
import { podPath } from 'orbiter:db';
import { openPod } from '@a83/orbiter-core';

const { id } = Astro.params;

const db  = openPod(podPath);
const row = db.db.prepare('SELECT mime_type, data FROM _media WHERE id = ?').get(id);
db.close();

if (!row) {
  return new Response('Not found', { status: 404 });
}

return new Response(row.data, {
  headers: {
    'Content-Type':  row.mime_type,
    'Cache-Control': 'public, max-age=31536000, immutable',
  },
});
---
