---
/**
 * /orbiter/media/[id] — serves a media BLOB from the .pod file
 */
import { podPath } from 'orbiter:db';
import { openPod } from '@orbiter/core';

// ── Auth ─────────────────────────────────────────────────────────────
{ const _db = openPod(podPath); const _u = _db.checkSession(Astro.cookies.get('orb_sess')?.value ?? ''); _db.close(); if (!_u) return new Response(null, { status: 401 }); }

const { id } = Astro.params;

const db  = openPod(podPath);
const row = db.db.prepare('SELECT mime_type, data FROM _media WHERE id = ?').get(id);
db.close();

if (!row) {
  return new Response('Not found', { status: 404 });
}

return new Response(row.data, {
  headers: {
    'Content-Type': row.mime_type,
    'Cache-Control': 'public, max-age=31536000, immutable',
  },
});
---
