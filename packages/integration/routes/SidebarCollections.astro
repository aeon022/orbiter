---
/**
 * SidebarCollections.astro
 * Shared component: renders the collections section of the sidebar.
 * Handles parent/child grouping with indented sub-items.
 *
 * Props:
 *   collections — array of { id, label, total, parent? }
 *   activeNav   — currently active nav id (collection id or 'dashboard' etc.)
 */
interface Props {
  collections: Array<{ id: string; label: string; total: number; parent?: string | null }>;
  activeNav:   string;
}
const { collections, activeNav } = Astro.props;

const topLevel = collections.filter(c => !c.parent);
const childMap: Record<string, typeof collections> = {};
for (const c of collections.filter(c => c.parent)) {
  if (!childMap[c.parent!]) childMap[c.parent!] = [];
  childMap[c.parent!].push(c);
}
---
{topLevel.map(col => {
  const kids = childMap[col.id] ?? [];
  return (
    <>
      <a href={`/orbiter/${col.id}`} class={`nav-item ${activeNav === col.id ? 'active' : ''}`}>
        <span class="nav-icon">▤</span><span class="nav-label">{col.label}</span>
        <span class="nav-badge">{col.total}</span>
      </a>
      {kids.length > 0 && (
        <div class="nav-children">
          {kids.map(kid => (
            <a href={`/orbiter/${kid.id}`} class={`nav-item nav-child ${activeNav === kid.id ? 'active' : ''}`}>
              <span class="nav-icon">◦</span><span class="nav-label">{kid.label}</span>
              <span class="nav-badge">{kid.total}</span>
            </a>
          ))}
        </div>
      )}
    </>
  );
})}

<style is:global>
  .nav-item { display:flex; align-items:center; gap:10px; padding:8px 18px; font-size:13px; color:var(--mid); text-decoration:none; position:relative; transition:color 0.12s,background 0.12s; }
  .nav-item:hover { color:var(--heading); background:var(--line2); }
  .nav-item.active { color:var(--heading); background:var(--accent-bg); font-weight:500; }
  .nav-item.active::before { content:""; position:absolute; left:0; top:0; bottom:0; width:2px; background:var(--gold); border-radius:0 1px 1px 0; }
  .nav-icon  { width:14px; text-align:center; font-size:11px; opacity:0.45; flex-shrink:0; }
  .nav-label { flex:1; min-width:0; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
  .nav-badge { margin-left:4px; flex-shrink:0; font-size:10px; color:var(--muted); background:var(--bg3); border:1px solid var(--line); padding:1px 7px; border-radius:3px; }
  .nav-children { border-left:1px solid var(--line); margin-left:18px; margin-bottom:4px; }
  .nav-child    { padding-left:20px; font-size:12px; }
  .nav-child .nav-icon { font-size:7px; opacity:0.3; }
</style>
