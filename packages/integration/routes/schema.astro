---
import { podPath } from 'orbiter:db';
import { openPod } from '@orbiter/core';
import AdminLayout from './AdminLayout.astro';
import { useTranslations } from '../src/i18n.js';

const locale = Astro.cookies.get('orb_locale')?.value ?? 'en';
const t = useTranslations(locale);

// ── Auth ─────────────────────────────────────────────────────────────
const _authDb = openPod(podPath);
const _u = _authDb.checkSession(Astro.cookies.get('orb_sess')?.value ?? '');
_authDb.close();
if (!_u) return Astro.redirect('/orbiter/login');

// ── Handle POST ───────────────────────────────────────────────────────
let postError = '';

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData();
  const action = form.get('_action')?.toString() ?? '';
  const db     = openPod(podPath);

  if (action === 'create') {
    const rawId  = form.get('col_id')?.toString().trim() ?? '';
    const id     = rawId.toLowerCase().replace(/[^a-z0-9_]/g, '_').replace(/^_+|_+$/g, '');
    const label  = form.get('col_label')?.toString().trim() ?? '';
    const schema = form.get('schema_json')?.toString() ?? '{}';

    if (!id || !label) {
      postError = t.schema_col_id_required;
      db.close();
    } else if (db.getCollection(id)) {
      postError = t.schema_col_id_exists.replace('{id}', id);
      db.close();
    } else {
      db.db.prepare('INSERT INTO _collections (id, label, schema) VALUES (?, ?, ?)').run(id, label, schema);
      db.close();
      return Astro.redirect(`/orbiter/schema?col=${id}&saved=1`);
    }

  } else if (action === 'update') {
    const id     = form.get('col_id')?.toString() ?? '';
    const label  = form.get('col_label')?.toString().trim() ?? '';
    const schema = form.get('schema_json')?.toString() ?? '{}';
    db.db.prepare('UPDATE _collections SET label = ?, schema = ? WHERE id = ?').run(label, schema, id);
    db.close();
    return Astro.redirect(`/orbiter/schema?col=${id}&saved=1`);

  } else if (action === 'delete') {
    const id = form.get('col_id')?.toString() ?? '';
    db.db.prepare('DELETE FROM _entries    WHERE collection_id = ?').run(id);
    db.db.prepare('DELETE FROM _collections WHERE id = ?').run(id);
    db.close();
    return Astro.redirect('/orbiter/schema?deleted=1');
  }
}

// ── GET ───────────────────────────────────────────────────────────────
const db = openPod(podPath);
const allCollections = db.getCollections().map(c => ({
  id:     c.id,
  label:  c.label,
  schema: c.schema ? JSON.parse(c.schema) : {},
  total:  db.getEntries(c.id).length,
}));
const formatVersion = db.getMeta('format_version') ?? '1';
db.close();

const selectedId = Astro.url.searchParams.get('col') ?? '';
const isNew      = Astro.url.searchParams.get('new') === '1';
const saved      = Astro.url.searchParams.get('saved') === '1';
const deleted    = Astro.url.searchParams.get('deleted') === '1';
const selected   = allCollections.find(c => c.id === selectedId) ?? null;

const FIELD_TYPES = [
  { value: 'string',   label: 'String — single line text' },
  { value: 'richtext', label: 'Rich Text — block editor' },
  { value: 'date',     label: 'Date' },
  { value: 'datetime', label: 'Date & time' },
  { value: 'array',    label: 'Array — tags, comma-separated' },
  { value: 'media',    label: 'Media — image / file' },
  { value: 'select',   label: 'Select — dropdown' },
  { value: 'url',      label: 'URL' },
  { value: 'number',   label: 'Number' },
  { value: 'weekdays', label: 'Weekdays' },
  { value: 'relation', label: 'Relation — link to collection' },
];

const fieldTypesJson = JSON.stringify(FIELD_TYPES);
---
<style is:global>
  /* Two-panel layout */
  .schema-layout { display:grid; grid-template-columns:220px 1fr; min-height:100%; }

  /* Left panel — collection list */
  .coll-panel { background:var(--bg1); border-right:1px solid var(--line); display:flex; flex-direction:column; }
  .coll-panel-head { padding:16px 16px 10px; border-bottom:1px solid var(--line); display:flex; align-items:center; justify-content:space-between; }
  .coll-panel-title { font-size:9px; letter-spacing:0.28em; text-transform:uppercase; color:var(--muted); }
  .btn-new-coll { font-size:18px; line-height:1; color:var(--gold); background:none; border:none; cursor:pointer; padding:0 2px; transition:opacity 0.12s; }
  .btn-new-coll:hover { opacity:0.7; }

  .coll-item { display:flex; align-items:center; justify-content:space-between; padding:9px 16px; font-size:11px; color:var(--mid); text-decoration:none; border-bottom:1px solid var(--line2); transition:background 0.1s,color 0.1s; cursor:pointer; position:relative; }
  .coll-item:hover { background:var(--line2); color:var(--heading); }
  .coll-item.active { background:var(--accent-bg); color:var(--heading); }
  .coll-item.active::before { content:""; position:absolute; left:0; top:0; bottom:0; width:2px; background:var(--gold); }
  .coll-item-count { font-size:9px; color:var(--muted); background:var(--bg3); border:1px solid var(--line); padding:1px 6px; }

  .coll-empty { padding:24px 16px; font-size:10px; color:var(--muted); line-height:1.8; }

  /* Right panel — editor */
  .editor-panel { padding:36px 44px; overflow-y:auto; max-width:780px; }

  .editor-empty { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:300px; gap:14px; color:var(--muted); text-align:center; }
  .editor-empty-icon { font-size:28px; opacity:0.2; }
  .editor-empty-text { font-size:11px; line-height:1.8; }

  .editor-head { margin-bottom:28px; padding-bottom:18px; border-bottom:1px solid var(--line); display:flex; align-items:flex-end; justify-content:space-between; gap:16px; }
  .editor-title { font-family:var(--serif); font-weight:200; font-size:24px; color:var(--heading); letter-spacing:0.04em; }
  .editor-sub { font-size:10px; color:var(--muted); margin-top:4px; }

  /* Meta fields */
  .meta-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:24px; }
  .field-group { display:flex; flex-direction:column; gap:5px; }
  .field-group label { font-size:10px; color:var(--muted); letter-spacing:0.06em; }
  .field-group input { background:var(--bg0); border:1px solid var(--line); padding:7px 10px; color:var(--heading); font-family:var(--mono); font-size:11px; outline:none; transition:border-color 0.15s; }
  .field-group input:focus { border-color:var(--accent); }
  .field-group input[readonly] { color:var(--muted); cursor:default; }
  .field-id-hint { font-size:9px; color:var(--muted); margin-top:2px; }

  /* Section label */
  .section-label { font-size:9px; letter-spacing:0.28em; text-transform:uppercase; color:var(--muted); margin-bottom:14px; display:flex; align-items:center; gap:8px; }
  .section-label::before { content:"—"; color:var(--gold); }

  /* Field rows — exact settings pattern */
  .field-rows { background:var(--bg2); border:1px solid var(--line); margin-bottom:14px; }
  .field-rows:empty::after { content:"No fields yet — click \"+ Add field\"."; display:block; padding:24px 18px; font-size:10px; color:var(--muted); text-align:center; }

  .field-row { display:grid; grid-template-columns:1fr 260px; align-items:center; gap:20px; padding:14px 18px; border-bottom:1px solid var(--line2); }
  .field-row:last-child { border-bottom:none; }

  .fr-left { display:flex; flex-direction:column; gap:2px; }
  .fr-right { display:flex; flex-direction:column; gap:6px; }
  .fr-foot { display:flex; align-items:center; justify-content:space-between; }

  /* All field inputs — exact copy of settings .field-input */
  .fi { width:100%; background:var(--bg0); border:1px solid var(--line); padding:7px 9px; color:var(--heading); font-family:var(--mono); font-size:11px; outline:none; appearance:none; transition:border-color 0.15s; }
  .fi:focus { border-color:var(--accent); }
  .fi::placeholder { color:var(--muted); opacity:0.7; }

  /* key = setting-label size */
  .fi-key { font-size:12px; }

  /* label = setting-desc size + muted */
  .fi-lbl { font-size:10px; color:var(--muted); }
  .fi-lbl:focus { color:var(--heading); }

  .fr-opts { display:none; }
  .fr-opts.on { display:block; }

  /* Required toggle */
  .req-wrap { display:flex; align-items:center; gap:6px; cursor:pointer; }
  .req-wrap input[type=checkbox] { display:none; }
  .req-box { width:14px; height:14px; flex-shrink:0; border:1px solid var(--line); background:var(--bg0); display:flex; align-items:center; justify-content:center; font-size:8px; color:transparent; transition:all 0.12s; }
  .req-txt { font-size:10px; color:var(--muted); transition:color 0.12s; }
  .req-wrap:has(input:checked) .req-box { background:var(--gold); border-color:var(--gold); color:var(--bg0); }
  .req-wrap:has(input:checked) .req-txt { color:var(--text); }

  /* Remove */
  .btn-rm { background:none; border:none; color:var(--line); font-size:13px; line-height:1; cursor:pointer; padding:2px 4px; transition:color 0.15s; }
  .btn-rm:hover { color:var(--crimson,#8b2635); }

  .btn-add-field { display:inline-flex; align-items:center; gap:7px; padding:8px 18px; border:1px solid var(--line); color:var(--mid); background:transparent; font-family:var(--mono); font-size:10px; cursor:pointer; transition:border-color 0.15s,color 0.15s; letter-spacing:0.06em; margin-bottom:0; }
  .btn-add-field:hover { border-color:var(--gold); color:var(--gold); }
  .btn-add-field::before { content:"+"; color:var(--gold); font-size:14px; line-height:1; }

  /* Actions */
  .editor-actions { display:flex; align-items:center; justify-content:space-between; gap:12px; padding:20px 0 0; border-top:1px solid var(--line); margin-top:20px; }
  .editor-actions-left { display:flex; align-items:center; gap:10px; }
  .btn-save { padding:9px 28px; background:var(--gold); border:1px solid var(--gold); color:var(--bg0); font-family:var(--mono); font-size:10px; letter-spacing:0.12em; text-transform:uppercase; cursor:pointer; transition:background 0.15s,border-color 0.15s; }
  .btn-save:hover { background:#7a5520; border-color:#7a5520; }
  .btn-delete { padding:9px 18px; background:transparent; border:1px solid var(--line); color:var(--muted); font-family:var(--mono); font-size:10px; letter-spacing:0.08em; cursor:pointer; transition:all 0.15s; }
  .btn-delete:hover { border-color:var(--crimson,#8b2635); color:var(--crimson,#8b2635); background:rgba(139,38,53,0.04); }

  /* Banners */
  .saved-banner { background:var(--jade-bg); border-bottom:1px solid rgba(30,107,80,0.15); padding:7px 44px; font-size:10px; color:var(--jade); display:flex; align-items:center; gap:6px; letter-spacing:0.04em; }
  .saved-banner::before { content:"✓"; }
  .error-banner { background:var(--crimson-bg,rgba(139,38,53,0.07)); border:1px solid rgba(139,38,53,0.15); padding:8px 12px; font-size:10px; color:var(--crimson,#8b2635); display:flex; align-items:center; gap:6px; margin-bottom:20px; }
  .error-banner::before { content:"✕"; }

  .delete-warn { font-size:10px; color:var(--muted); padding:10px 12px; background:var(--gold-bg); border:1px solid rgba(154,110,48,0.2); margin-bottom:16px; line-height:1.7; }
</style>
<AdminLayout
  title="Schema"
  activeNav="schema"
  breadcrumbs={[{label:'Dashboard',href:'/orbiter'},{label:'Collections'}]}
  collections={allCollections}
  podInfo={`v${formatVersion} format`}
  locale={locale}
>
  {saved   && <div class="saved-banner">{t.schema_saved}</div>}
  {deleted && <div class="saved-banner">{t.schema_deleted}</div>}

  <div class="schema-layout">

    <!-- Left: collection list -->
    <div class="coll-panel">
      <div class="coll-panel-head">
        <span class="coll-panel-title">Collections</span>
        <a href="/orbiter/schema?new=1" class="btn-new-coll" title="Neue Collection">+</a>
      </div>

      {allCollections.length === 0
        ? <div class="coll-empty">{t.schema_empty_panel}</div>
        : allCollections.map(c => (
            <a href={`/orbiter/schema?col=${c.id}`} class={`coll-item ${c.id === selectedId ? 'active' : ''}`}>
              <span>{c.label}</span>
              <span class="coll-item-count">{c.total}</span>
            </a>
          ))
      }
    </div>

    <!-- Right: editor -->
    <div class="editor-panel">

      {postError && <div class="error-banner">{postError}</div>}

      {!selected && !isNew && (
        <div class="editor-empty">
          <div class="editor-empty-icon">◈</div>
          <div class="editor-empty-text">
            {t.schema_empty_panel}
          </div>
          <a href="/orbiter/schema?new=1" style="font-size:10px;color:var(--gold);text-decoration:none;border:1px solid var(--gold);padding:6px 16px;letter-spacing:0.08em;">{t.schema_new_btn}</a>
        </div>
      )}

      {(selected || isNew) && (
        <form method="POST" id="schema-form">
          <input type="hidden" name="_action" value={selected ? 'update' : 'create'} />
          <input type="hidden" name="schema_json" id="schema-json-input" value="{}" />

          <div class="editor-head">
            <div>
              <div class="editor-title">{selected ? selected.label : t.schema_new}</div>
              {selected && <div class="editor-sub">id: {selected.id} · {selected.total} {t.entries}</div>}
            </div>
          </div>

          <div class="meta-row">
            <div class="field-group">
              <label>{t.schema_col_id}</label>
              {selected
                ? <><input name="col_id" value={selected.id} readonly /><div class="field-id-hint">{t.schema_col_id_hint}</div></>
                : <><input name="col_id" placeholder="e.g. news, products, team" id="col-id-input" /><div class="field-id-hint">{t.schema_col_id_hint}</div></>
              }
            </div>
            <div class="field-group">
              <label>{t.schema_col_label}</label>
              <input name="col_label" value={selected?.label ?? ''} placeholder="e.g. News, Products, Team" />
            </div>
          </div>

          <div class="section-label">{t.schema_fields}</div>

          {selected && selected.total > 0 && (
            <div class="delete-warn">
              {t.schema_field_non_destructive}
            </div>
          )}

          <div class="field-rows" id="field-rows"></div>

          <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding-top:20px;border-top:1px solid var(--line);margin-top:20px;">
            <div style="display:flex;align-items:center;gap:10px;">
              <button type="submit"
                style="padding:9px 28px;background:var(--gold);border:1px solid var(--gold);color:var(--bg0);font-family:var(--mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;"
                onmouseenter="this.style.background='var(--btn-hover,#7a5520)';this.style.borderColor='var(--btn-hover,#7a5520)'"
                onmouseleave="this.style.background='var(--gold)';this.style.borderColor='var(--gold)'"
              >{t.schema_save}</button>
              <button type="button"
                style="display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border:1px solid var(--line);color:var(--mid);background:transparent;font-family:var(--mono);font-size:10px;letter-spacing:0.06em;cursor:pointer;"
                onmouseenter="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'"
                onmouseleave="this.style.borderColor='var(--line)';this.style.color='var(--mid)'"
                onclick="addField()"
              >{t.schema_add_field}</button>
            </div>
            {selected && (
              <button
                type="submit"
                formaction="/orbiter/schema"
                name="_action"
                value="delete"
                style="padding:9px 18px;background:transparent;border:1px solid var(--line);color:var(--muted);font-family:var(--mono);font-size:10px;letter-spacing:0.08em;cursor:pointer;"
                onmouseenter="this.style.borderColor='#8b2635';this.style.color='#8b2635';this.style.background='rgba(139,38,53,0.04)'"
                onmouseleave="this.style.borderColor='var(--line)';this.style.color='var(--muted)';this.style.background='transparent'"
                onclick={`return confirmDelete('${selected.label}', ${selected.total})`}
              >{t.schema_delete_col}</button>
            )}
          </div>
        </form>
      )}

    </div>
  </div>
</AdminLayout>

<script define:vars={{ selectedSchema: selected?.schema ?? null, isNew, fieldTypesJson, allCollsJson: JSON.stringify(allCollections.filter(c => c.id !== selectedId).map(c => ({id: c.id, label: c.label}))), phKey: t.schema_field_key, phLabel: t.schema_field_lbl, txtRequired: t.schema_required, confirmEmpty: t.schema_delete_confirm_empty, confirmEntries: t.schema_delete_confirm_entries }}>
const FIELD_TYPES = JSON.parse(fieldTypesJson);
const ALL_COLLS = JSON.parse(allCollsJson);
function collOptions(sel) {
  return '<option value="">— select collection —</option>' +
    ALL_COLLS.map(c => `<option value="${c.id}"${c.id === sel ? ' selected' : ''}>${c.label} (${c.id})</option>`).join('');
}

// Shared inline style strings — guaranteed to apply regardless of Astro/Vite CSS processing
var S = {
  row:    'display:grid;grid-template-columns:1fr 260px;align-items:center;gap:20px;padding:14px 18px;border-bottom:1px solid var(--line2);background:var(--bg2);',
  left:   'display:flex;flex-direction:column;gap:6px;',
  right:  'display:flex;flex-direction:column;gap:6px;',
  foot:   'display:flex;align-items:center;justify-content:space-between;margin-top:2px;',
  input:  'width:100%;background:var(--bg0);border:1px solid var(--line);padding:7px 9px;color:var(--heading);font-family:var(--mono);font-size:11px;outline:none;appearance:none;box-sizing:border-box;',
  iKey:   'width:100%;background:var(--bg0);border:1px solid var(--line);padding:7px 9px;color:var(--heading);font-family:var(--mono);font-size:12px;outline:none;box-sizing:border-box;',
  iLbl:   'width:100%;background:var(--bg0);border:1px solid var(--line);padding:6px 9px;color:var(--muted);font-family:var(--mono);font-size:10px;outline:none;box-sizing:border-box;',
  reqW:   'display:flex;align-items:center;gap:6px;cursor:pointer;',
  reqBox: 'width:14px;height:14px;flex-shrink:0;border:1px solid var(--line);background:var(--bg0);display:flex;align-items:center;justify-content:center;font-size:8px;',
  reqTxt: 'font-size:10px;color:var(--muted);',
  btnRm:  'background:none;border:none;color:var(--muted);font-size:13px;line-height:1;cursor:pointer;padding:2px 6px;',
};

function typeOptions(sel) {
  return FIELD_TYPES.map(t =>
    `<option value="${t.value}"${t.value === sel ? ' selected' : ''}>${t.value} — ${t.label.split(' — ')[1] ?? t.label}</option>`
  ).join('');
}

function addField(key = '', label = '', type = 'string', required = false, options = '', collection = '', multiple = true) {
  const rows = document.getElementById('field-rows');
  const div  = document.createElement('div');
  div.className = 'field-row';
  div.setAttribute('style', S.row);

  div.innerHTML = `
    <div class="fr-left" style="${S.left}">
      <input class="f-key"   style="${S.iKey}" placeholder="${phKey}"   value="${key}"   />
      <input class="f-label" style="${S.iLbl}" placeholder="${phLabel}" value="${label}" />
    </div>
    <div class="fr-right" style="${S.right}">
      <select class="f-type" style="${S.input}" onchange="onTypeChange(this)">${typeOptions(type)}</select>
      <div class="fr-opts-select" style="display:${type === 'select' ? 'block' : 'none'}">
        <input class="f-options" style="${S.input}" placeholder="opt1, opt2, opt3" value="${options}" />
      </div>
      <div class="fr-opts-relation" style="display:${type === 'relation' ? 'flex' : 'none'};flex-direction:column;gap:4px;">
        <select class="f-rel-col" style="${S.input}">${collOptions(collection)}</select>
        <label style="${S.reqW}">
          <input type="checkbox" class="f-multiple"${multiple ? ' checked' : ''} style="display:none" />
          <span class="mul-box" style="${S.reqBox}${multiple ? 'background:var(--gold);border-color:var(--gold);color:var(--bg0);' : 'color:transparent;'}">${multiple ? '✓' : ''}</span>
          <span style="${S.reqTxt}">Multiple</span>
        </label>
      </div>
      <div class="fr-foot" style="${S.foot}">
        <label style="${S.reqW}">
          <input type="checkbox" class="f-required"${required ? ' checked' : ''} style="display:none" />
          <span class="req-box" style="${S.reqBox}${required ? 'background:var(--gold);border-color:var(--gold);color:var(--bg0);' : 'color:transparent;'}">${required ? '✓' : ''}</span>
          <span style="${S.reqTxt}">${txtRequired}</span>
        </label>
        <button type="button" class="btn-rm" style="${S.btnRm}" onclick="this.closest('.field-row').remove()" title="remove">✕</button>
      </div>
    </div>
  `;

  // Update req-box visually when checkbox changes
  const cb  = div.querySelector('.f-required');
  const box = div.querySelector('.req-box');
  cb.addEventListener('change', function() {
    box.style.background    = this.checked ? 'var(--gold)' : 'var(--bg0)';
    box.style.borderColor   = this.checked ? 'var(--gold)' : 'var(--line)';
    box.style.color         = this.checked ? 'var(--bg0)'  : 'transparent';
    box.textContent         = this.checked ? '✓' : '';
  });

  const mulCb  = div.querySelector('.f-multiple');
  const mulBox = div.querySelector('.mul-box');
  if (mulCb && mulBox) {
    mulCb.addEventListener('change', function() {
      mulBox.style.background  = this.checked ? 'var(--gold)' : 'var(--bg0)';
      mulBox.style.borderColor = this.checked ? 'var(--gold)' : 'var(--line)';
      mulBox.style.color       = this.checked ? 'var(--bg0)'  : 'transparent';
      mulBox.textContent       = this.checked ? '✓' : '';
    });
  }

  rows.appendChild(div);
}

function onTypeChange(sel) {
  const row = sel.closest('.field-row');
  row.querySelector('.fr-opts-select').style.display   = sel.value === 'select'   ? 'block' : 'none';
  row.querySelector('.fr-opts-relation').style.display = sel.value === 'relation' ? 'flex'  : 'none';
}

function serializeSchema() {
  const rows   = document.querySelectorAll('#field-rows .field-row');
  const schema = {};
  rows.forEach(row => {
    const key  = row.querySelector('.f-key').value.trim().toLowerCase().replace(/[^a-z0-9_]/g, '_');
    if (!key) return;
    const type = row.querySelector('.f-type').value;
    const entry = {
      type,
      required: row.querySelector('.f-required').checked,
      label:    row.querySelector('.f-label').value.trim() || key,
    };
    if (type === 'select') {
      const raw = row.querySelector('.f-options').value;
      entry.options = raw.split(',').map(s => s.trim()).filter(Boolean);
    }
    if (type === 'relation') {
      entry.collection = row.querySelector('.f-rel-col').value;
      entry.multiple   = row.querySelector('.f-multiple').checked;
    }
    schema[key] = entry;
  });
  document.getElementById('schema-json-input').value = JSON.stringify(schema);
}

document.getElementById('schema-form')?.addEventListener('submit', serializeSchema);

// Populate existing fields on page load
if (selectedSchema) {
  Object.entries(selectedSchema).forEach(([key, field]) => {
    const opts = field.options ? field.options.join(', ') : '';
    addField(key, field.label ?? key, field.type ?? 'string', !!field.required, opts, field.collection ?? '', field.multiple !== false);
  });
} else if (isNew) {
  // default: start with a title field
  addField('title', 'Title', 'string', true);
}

// Slug-ify collection ID while typing
const idInput = document.getElementById('col-id-input');
idInput?.addEventListener('input', function() {
  const raw = this.value.toLowerCase().replace(/[^a-z0-9_]/g, '_').replace(/^_+/, '');
  if (raw !== this.value) {
    const pos = this.selectionStart;
    this.value = raw;
    this.setSelectionRange(pos, pos);
  }
});

function confirmDelete(label, count) {
  const msg = count > 0
    ? confirmEntries.replace('{label}', label).replace('{count}', count)
    : confirmEmpty.replace('{label}', label);
  return confirm(msg);
}
</script>
