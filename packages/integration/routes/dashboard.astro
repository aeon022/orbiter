---
export const prerender = false;
/**
 * /orbiter — Admin Dashboard
 * Injected by @a83/orbiter-integration
 */
import { podPath } from 'orbiter:db';
import { openPod } from '@a83/orbiter-core';
import { useTranslations } from '../src/i18n.js';
import AdminLayout from './AdminLayout.astro';

// ── Auth + First-run check ────────────────────────────────────────────
{
  const _db = openPod(podPath);
  const _u  = _db.checkSession(Astro.cookies.get('orb_sess')?.value ?? '');
  if (!_u) { _db.close(); return Astro.redirect('/orbiter/login'); }
  const _setupDone     = (_db.getMeta('setup.complete') ?? '') === '1';
  const _hasCollections = _db.getCollections().length > 0;
  _db.close();
  if (!_setupDone && !_hasCollections) return Astro.redirect('/orbiter/setup');
}

// ── Handle POST (notes / todos API) ──────────────────────────────────
if (Astro.request.method === 'POST') {
  const body = await Astro.request.json().catch(() => null);
  if (body?.action === 'save-notes' || body?.action === 'save-todos') {
    const db2 = openPod(podPath);
    const key = body.action === 'save-notes' ? 'dashboard.notes' : 'dashboard.todos';
    db2.setMeta(key, body.value ?? '');
    db2.close();
    return new Response(JSON.stringify({ ok: true }), { headers: { 'Content-Type': 'application/json' } });
  }
  return new Response(JSON.stringify({ ok: false }), { status: 400, headers: { 'Content-Type': 'application/json' } });
}

const db          = openPod(podPath);
const collections = db.getCollections();
const meta        = {
  siteName: db.getMeta('site.name') ?? 'Orbiter',
  siteUrl:  db.getMeta('site.url')  ?? '',
};

const allCollections = db.getCollections().map(c => ({
  id: c.id, label: c.label, total: db.getEntries(c.id).length,
  parent: db.getMeta(`collection.${c.id}.parent`) ?? null,
}));

const stats = allCollections.map(col => {
  const all       = db.getEntries(col.id);
  const published = all.filter(e => e.status === 'published').length;
  const drafts    = all.filter(e => e.status === 'draft').length;
  return { ...col, total: all.length, published, drafts };
});
const topLevelStats = stats.filter(s => !s.parent);

const totalEntries   = stats.reduce((n, s) => n + s.total, 0);
const totalPublished = stats.reduce((n, s) => n + s.published, 0);
const totalDrafts    = totalEntries - totalPublished;

const recent = collections
  .flatMap(col => db.getEntries(col.id).map(e => ({ ...e, collectionId: col.id, collectionLabel: col.label })))
  .sort((a, b) => new Date(b.updated_at) - new Date(a.updated_at))
  .slice(0, 10);

const mediaCount  = db.db.prepare('SELECT COUNT(*) as n FROM _media').get().n;
const hasWebhook  = !!(db.getMeta('build.webhook_url'));
const adminLocale = db.getMeta('site.locale') ?? 'en-US';
const initNotes   = db.getMeta('dashboard.notes') ?? '';
const initTodos   = JSON.parse(db.getMeta('dashboard.todos') ?? '[]');

db.close();

const locale = Astro.cookies.get('orb_locale')?.value ?? 'en';
const t = useTranslations(locale);

const today = new Date().toLocaleDateString(adminLocale, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
---
<style>
  /* Hero */
  .hero { padding:32px 40px 24px; border-bottom:1px solid var(--line); background:var(--bg2); display:flex; align-items:flex-end; justify-content:space-between; gap:24px; }
  .hero-site { font-family:var(--serif); font-weight:200; font-size:28px; color:var(--heading); letter-spacing:0.04em; line-height:1.1; margin-bottom:6px; }
  .hero-date { font-size:10px; color:var(--muted); letter-spacing:0.04em; }
  .hero-right { display:flex; align-items:center; gap:10px; flex-shrink:0; }
  .hero-url { font-size:10px; color:var(--accent); text-decoration:none; border:1px solid var(--line); padding:5px 12px; transition:border-color 0.15s; }
  .hero-url:hover { border-color:var(--accent); }
  .btn-deploy { display:flex; align-items:center; gap:6px; padding:7px 16px; background:transparent; border:1px solid var(--gold); color:var(--gold); font-family:var(--mono); font-size:10px; letter-spacing:0.13em; text-transform:uppercase; cursor:pointer; border-radius:var(--radius); transition:all 0.15s; }
  .btn-deploy:hover { background:var(--gold); color:var(--bg0); }
  .btn-deploy:disabled { opacity:0.5; cursor:not-allowed; }
  .deploy-status { font-size:10px; color:var(--muted); }

  /* Stats row */
  .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:0; border-bottom:1px solid var(--line); }
  .stat-cell { padding:20px 24px; border-right:1px solid var(--line); position:relative; }
  .stat-cell:last-child { border-right:none; }
  .stat-label { font-size:9px; letter-spacing:0.26em; text-transform:uppercase; color:var(--muted); margin-bottom:10px; }
  .stat-num { font-family:var(--serif); font-weight:200; font-size:36px; color:var(--heading); line-height:1; margin-bottom:6px; }
  .stat-sub { font-size:10px; color:var(--muted); display:flex; align-items:center; gap:6px; }
  .stat-bar { height:2px; background:var(--line); margin-top:12px; }
  .stat-bar-fill { height:100%; transition:width 0.4s; }
  .stat-bar-fill.jade { background:var(--jade); }
  .stat-bar-fill.gold { background:var(--gold); }
  .stat-bar-fill.accent { background:var(--accent); }
  .stat-dot { width:5px; height:5px; border-radius:50%; flex-shrink:0; }
  .stat-dot.jade { background:var(--jade); }
  .stat-dot.gold { background:var(--gold); }

  /* Content area */
  .content { display:grid; grid-template-columns:1fr 300px; }
  .content-main { padding:28px 32px; border-right:1px solid var(--line); }
  .content-side { padding:24px 0; }

  /* Section headers */
  .section-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
  .section-title { font-size:9px; letter-spacing:0.26em; text-transform:uppercase; color:var(--text); display:flex; align-items:center; gap:8px; }
  .section-title::before { content:"—"; color:var(--gold); font-size:8px; }
  .section-link { font-size:10px; color:var(--accent); text-decoration:none; }
  .section-link:hover { color:var(--heading); }

  /* Recent entries */
  .entry-list { border:1px solid var(--line); }
  .entry-row { display:grid; grid-template-columns:1fr 90px 70px; align-items:center; gap:16px; padding:11px 14px; border-bottom:1px solid var(--line2); text-decoration:none; transition:background 0.1s; }
  .entry-row:hover { background:var(--line2); }
  .entry-row:last-child { border-bottom:none; }
  .entry-name { font-size:12px; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .entry-coll { font-size:9px; color:var(--muted); margin-top:1px; letter-spacing:0.04em; }
  .entry-date { font-size:10px; color:var(--muted); text-align:right; }
  .pill { font-size:9px; padding:2px 7px; letter-spacing:0.06em; text-align:center; }
  .pill.published { color:var(--jade); background:var(--jade-bg); }
  .pill.draft { color:var(--gold); background:var(--gold-bg); }

  /* Side panels */
  .side-section { padding:0 20px 24px; }
  .side-section + .side-section { border-top:1px solid var(--line); padding-top:20px; }

  /* Support widget */
  .support-widget { margin:0 20px 24px; border:1px solid var(--line); padding:14px 16px; }
  .support-label { font-size:8px; letter-spacing:0.28em; text-transform:uppercase; color:var(--muted); margin-bottom:7px; display:flex; align-items:center; gap:6px; }
  .support-label::before { content:"◆"; color:var(--gold); font-size:6px; }
  .support-text { font-size:10px; color:var(--muted); line-height:1.7; margin-bottom:12px; }
  .btn-support { display:block; padding:7px 10px; border:1px solid var(--gold); color:var(--gold); font-family:var(--mono); font-size:9px; letter-spacing:0.1em; text-transform:uppercase; text-decoration:none; text-align:center; border-radius:var(--radius); transition:all 0.15s; }
  .btn-support:hover { background:var(--gold); color:var(--bg0); }

  /* Collection cards */
  .coll-card { padding:12px 0; border-bottom:1px solid var(--line2); }
  .coll-card:last-child { border-bottom:none; }
  .coll-card-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
  .coll-card-name { font-size:12px; color:var(--heading); display:flex; align-items:center; gap:7px; }
  .coll-card-name::before { content:"▤"; font-size:9px; color:var(--muted); }
  .coll-card-count { font-size:10px; color:var(--muted); }
  .coll-progress { height:2px; background:var(--line); margin-bottom:6px; }
  .coll-progress-fill { height:100%; background:var(--jade); transition:width 0.4s; }
  .coll-card-meta { display:flex; justify-content:space-between; font-size:9px; color:var(--muted); }
  .coll-card-meta .pub { color:var(--jade); }
  .coll-actions { display:flex; gap:6px; margin-top:8px; }
  .btn-sm { font-size:9px; padding:4px 10px; border:1px solid var(--line); color:var(--mid); background:transparent; font-family:var(--mono); cursor:pointer; text-decoration:none; letter-spacing:0.06em; display:inline-flex; align-items:center; gap:4px; border-radius:var(--radius); transition:all 0.12s; }
  .btn-sm:hover { border-color:var(--gold); color:var(--gold); }
  .btn-sm.primary { border-color:var(--gold); color:var(--gold); }
  .btn-sm.primary:hover { background:var(--gold); color:var(--bg0); }

  /* Empty state */
  .empty { padding:40px 20px; text-align:center; color:var(--muted); font-size:11px; border:1px solid var(--line); line-height:2; }

  /* Workspace (notes + todos) */
  .workspace { display:grid; grid-template-columns:1fr 1fr; border-top:1px solid var(--line); }
  .ws-panel { padding:24px 32px; }
  .ws-panel + .ws-panel { border-left:1px solid var(--line); }
  .ws-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
  .ws-save-indicator { font-size:9px; color:var(--muted); transition:color 0.2s; }
  .notes-area { width:100%; min-height:140px; resize:vertical; background:var(--bg1); border:1px solid var(--line); padding:12px 14px; color:var(--text); font-family:var(--mono); font-size:13px; line-height:1.8; outline:none; border-radius:var(--radius); transition:border-color 0.15s; }
  .notes-area:focus { border-color:var(--accent); }
  .todo-input-row { display:flex; align-items:center; gap:0; margin-bottom:12px; border:1px solid var(--line); background:var(--bg1); border-radius:var(--radius); }
  .todo-prompt { font-family:var(--mono); font-size:11px; color:var(--muted); padding:7px 6px 7px 10px; flex-shrink:0; user-select:none; }
  .todo-input { flex:1; background:transparent; border:none; padding:7px 4px; color:var(--text); font-family:var(--mono); font-size:11px; outline:none; }
  .todo-add-btn { padding:7px 12px; background:transparent; border:none; border-left:1px solid var(--line); color:var(--muted); font-family:var(--mono); font-size:10px; cursor:pointer; letter-spacing:0.06em; transition:color 0.12s; flex-shrink:0; }
  .todo-add-btn:hover { color:var(--heading); }
  .todo-footer { display:flex; align-items:center; justify-content:space-between; padding-top:8px; min-height:20px; }
  .todo-count { font-size:9px; color:var(--muted); }
  .todo-clear-btn { background:none; border:none; font-family:var(--mono); font-size:9px; color:var(--muted); cursor:pointer; padding:0; letter-spacing:0.04em; transition:color 0.12s; }
  .todo-clear-btn:hover { color:var(--heading); }
  .ws-export-btn { background:none; border:1px solid var(--line); color:var(--muted); font-family:var(--mono); font-size:9px; padding:2px 8px; cursor:pointer; letter-spacing:0.06em; transition:all 0.12s; }
  .ws-export-btn:hover { border-color:var(--accent); color:var(--accent); }
</style>
<AdminLayout
  title={meta.siteName}
  activeNav="dashboard"
  breadcrumbs={[]}
  collections={allCollections}
  podInfo={`${totalEntries} ${t.entries} · ${collections.length} ${t.dashboard_collections}`}
  locale={locale}
>

  <!-- Hero -->
  <div class="hero">
    <div>
      <div class="hero-site">{meta.siteName}</div>
      <div class="hero-date">{today}</div>
    </div>
    <div class="hero-right">
      <span id="deploy-status" class="deploy-status"></span>
      {meta.siteUrl && (
        <a href={meta.siteUrl} target="_blank" class="hero-url">↗ {t.dashboard_open_site}</a>
      )}
      {hasWebhook && (
        <button class="btn-deploy" id="deploy-btn" onclick="triggerDeploy()">↑ Deploy</button>
      )}
    </div>
  </div>

  <!-- Stats row -->
  <div class="stats-row">
    <div class="stat-cell">
      <div class="stat-label">{t.dashboard_total}</div>
      <div class="stat-num">{totalEntries}</div>
      <div class="stat-sub">{collections.length} {t.dashboard_collections}</div>
      <div class="stat-bar"><div class="stat-bar-fill accent" style={`width:100%`}></div></div>
    </div>
    <div class="stat-cell">
      <div class="stat-label">{t.published}</div>
      <div class="stat-num">{totalPublished}</div>
      <div class="stat-sub">
        <span class="stat-dot jade"></span>
        {totalEntries > 0 ? Math.round(totalPublished / totalEntries * 100) : 0}% {t.dashboard_total.toLowerCase()}
      </div>
      <div class="stat-bar"><div class="stat-bar-fill jade" style={`width:${totalEntries > 0 ? Math.round(totalPublished / totalEntries * 100) : 0}%`}></div></div>
    </div>
    <div class="stat-cell">
      <div class="stat-label">{t.dashboard_drafts}</div>
      <div class="stat-num">{totalDrafts}</div>
      <div class="stat-sub">
        <span class="stat-dot gold"></span>
        {t.draft}
      </div>
      <div class="stat-bar"><div class="stat-bar-fill gold" style={`width:${totalEntries > 0 ? Math.round(totalDrafts / totalEntries * 100) : 0}%`}></div></div>
    </div>
    <div class="stat-cell">
      <div class="stat-label">Media</div>
      <div class="stat-num">{mediaCount}</div>
      <div class="stat-sub">{t.dashboard_files}</div>
      <div class="stat-bar"><div class="stat-bar-fill accent" style="width:60%"></div></div>
    </div>
  </div>

  <!-- Content -->
  <div class="content">

    <!-- Recent entries -->
    <div class="content-main">
      <div class="section-head">
        <div class="section-title">{t.dashboard_recently}</div>
      </div>
      {recent.length > 0 ? (
        <div class="entry-list">
          {recent.map(entry => (
            <a href={`/orbiter/${entry.collectionId}/${entry.slug}`} class="entry-row">
              <div>
                <div class="entry-name">{entry.data?.title ?? entry.slug}</div>
                <div class="entry-coll">{entry.collectionLabel}</div>
              </div>
              <div class="entry-date">{new Date(entry.updated_at).toLocaleDateString(adminLocale)}</div>
              <div class={`pill ${entry.status}`}>{entry.status === 'published' ? t.dashboard_live : t.dashboard_draft_dot}</div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty">
          {t.dashboard_no_entries}
        </div>
      )}
    </div>

    <!-- Side: Collections + Quick Actions -->
    <div class="content-side">
      <div class="side-section">
        <div class="section-head">
          <div class="section-title">{t.dashboard_collections}</div>
        </div>
        {topLevelStats.map(col => {
          const pct = col.total > 0 ? Math.round(col.published / col.total * 100) : 0;
          return (
            <div class="coll-card">
              <div class="coll-card-head">
                <div class="coll-card-name">{col.label}</div>
                <div class="coll-card-count">{col.total}</div>
              </div>
              <div class="coll-progress">
                <div class="coll-progress-fill" style={`width:${pct}%`}></div>
              </div>
              <div class="coll-card-meta">
                <span class="pub">{col.published} {t.published}</span>
                <span>{col.drafts} {t.dashboard_drafts}</span>
              </div>
              <div class="coll-actions">
                <a href={`/orbiter/${col.id}/new`} class="btn-sm primary">+ {t.new_entry}</a>
                <a href={`/orbiter/${col.id}`} class="btn-sm">{t.dashboard_show_all}</a>
              </div>
            </div>
          );
        })}
      </div>

      <div class="support-widget">
        <div class="support-label">Support</div>
        <div class="support-text">{t.dashboard_support_text}</div>
        <a href="https://buy.polar.sh/polar_cl_SFvmYDegcsKDv8O8ZylLlIiXzyNRM7Br9nBx942rj4Q" class="btn-support" target="_blank" rel="noopener">{t.dashboard_support_btn}</a>
      </div>

    </div>

  </div>

  <!-- Workspace: Notes + Todos -->
  <div class="workspace">

    <!-- Notes -->
    <div class="ws-panel">
      <div class="ws-head">
        <div class="section-title">Notes</div>
        <div style="display:flex;align-items:center;gap:10px;">
          <span class="ws-save-indicator" id="notes-indicator"></span>
          <button class="ws-export-btn" onclick="exportNotes()" title="Export as Markdown">↓ md</button>
        </div>
      </div>
      <textarea class="notes-area" id="notes-area" placeholder="Jot something down…">{initNotes}</textarea>
    </div>

    <!-- Todos -->
    <div class="ws-panel">
      <div class="ws-head">
        <div class="section-title">To-Do</div>
        <div style="display:flex;align-items:center;gap:10px;">
          <span class="ws-save-indicator" id="todos-indicator"></span>
          <button class="ws-export-btn" onclick="exportTodos()" title="Export as Markdown">↓ md</button>
        </div>
      </div>
      <div class="todo-input-row">
        <span class="todo-prompt">›</span>
        <input class="todo-input" id="todo-input" placeholder="Add a task…" type="text" />
        <button class="todo-add-btn" onclick="todoAdd()">↵ add</button>
      </div>
      <div id="todo-list"></div>
      <div class="todo-footer">
        <span class="todo-count" id="todo-count"></span>
        <button class="todo-clear-btn" id="todo-clear-btn" onclick="todoClearDone()" style="display:none">Clear done</button>
      </div>
    </div>

  </div>

  <script define:vars={{ initNotes, initTodos }}>
    // ── Deploy ────────────────────────────────────────────────────────
    window.triggerDeploy = async function() {
      const btn    = document.getElementById('deploy-btn');
      const status = document.getElementById('deploy-status');
      btn.disabled = true;
      btn.textContent = '↑ Deploying…';
      status.textContent = '';
      try {
        const res  = await fetch('/orbiter/build', { method: 'POST' });
        const json = await res.json();
        if (json.ok) {
          status.textContent = '✓ Build triggered';
          status.style.color = 'var(--jade)';
        } else {
          status.textContent = json.error ?? 'Error ' + json.status;
          status.style.color = '#8b2635';
        }
      } catch {
        status.textContent = 'Network error';
        status.style.color = '#8b2635';
      }
      btn.textContent = '↑ Deploy';
      btn.disabled = false;
    }

    // ── Notes ─────────────────────────────────────────────────────────
    var notesTimer = null;
    var notesIndicator = document.getElementById('notes-indicator');

    document.getElementById('notes-area').addEventListener('input', function() {
      notesIndicator.textContent = '●  unsaved';
      notesIndicator.style.color = 'var(--gold)';
      clearTimeout(notesTimer);
      notesTimer = setTimeout(saveNotes, 1500);
    });

    async function saveNotes() {
      notesIndicator.textContent = '↑  saving…';
      notesIndicator.style.color = 'var(--muted)';
      var val = document.getElementById('notes-area').value;
      try {
        await fetch('/orbiter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'save-notes', value: val }),
        });
        notesIndicator.textContent = '✓  saved';
        notesIndicator.style.color = 'var(--jade)';
        setTimeout(function() { notesIndicator.textContent = ''; }, 2000);
      } catch {
        notesIndicator.textContent = '✕  error';
        notesIndicator.style.color = '#8b2635';
      }
    }

    // ── Todos ─────────────────────────────────────────────────────────
    var todos = Array.isArray(initTodos) ? initTodos : [];
    var todosIndicator = document.getElementById('todos-indicator');

    var ROW    = 'display:flex;align-items:center;gap:10px;padding:5px 0;border-bottom:1px solid #e0dbd0;';
    var ROW_D  = 'display:flex;align-items:center;gap:10px;padding:5px 0;border-bottom:1px solid #e0dbd0;opacity:0.45;';
    var BTN    = 'background:none;border:none;font-family:"DM Mono",monospace;font-size:11px;cursor:pointer;padding:0;flex-shrink:0;white-space:nowrap;';

    function todoRender() {
      var list     = document.getElementById('todo-list');
      var count    = document.getElementById('todo-count');
      var clearBtn = document.getElementById('todo-clear-btn');
      list.innerHTML = '';

      var doneCount = todos.filter(function(t) { return t.done; }).length;
      var openCount = todos.length - doneCount;

      clearBtn.style.display = doneCount > 0 ? '' : 'none';
      count.textContent = todos.length
        ? openCount + ' open' + (doneCount ? ' · ' + doneCount + ' done' : '')
        : '';

      if (!todos.length) {
        var empty = document.createElement('div');
        empty.style.cssText = 'font-size:11px;color:#a09890;padding:8px 0;font-family:"DM Mono",monospace;';
        empty.textContent = 'No tasks yet';
        list.appendChild(empty);
        return;
      }

      todos.forEach(function(todo, idx) {
        var item = document.createElement('div');
        item.style.cssText = todo.done ? ROW_D : ROW;
        if (idx === 0) item.style.borderTop = '1px solid #e0dbd0';

        var toggle = document.createElement('button');
        toggle.style.cssText = BTN + 'color:' + (todo.done ? '#1e6b50' : '#a09890') + ';';
        toggle.textContent   = todo.done ? '[×]' : '[ ]';
        toggle.addEventListener('click', function() { todoToggle(idx); });

        var text = document.createElement('div');
        text.style.cssText = 'flex:1;min-width:0;font-size:11px;font-family:"DM Mono",monospace;color:' +
          (todo.done ? '#a09890' : '#3a3228') + ';' +
          (todo.done ? 'text-decoration:line-through;' : '') +
          'white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';
        text.textContent = todo.text;
        text.title       = todo.text;

        var del = document.createElement('button');
        del.style.cssText = BTN + 'color:#e0dbd0;';
        del.textContent   = '[del]';
        del.addEventListener('mouseenter', function() { del.style.color = '#706860'; });
        del.addEventListener('mouseleave', function() { del.style.color = '#e0dbd0'; });
        del.addEventListener('click', function() { todoDelete(idx); });

        item.appendChild(toggle);
        item.appendChild(text);
        item.appendChild(del);
        list.appendChild(item);
      });
    }

    async function todoSave() {
      todosIndicator.textContent = '✓  saved';
      todosIndicator.style.color = 'var(--jade)';
      setTimeout(function() { todosIndicator.textContent = ''; }, 1500);
      await fetch('/orbiter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'save-todos', value: JSON.stringify(todos) }),
      }).catch(function() {});
    }

    window.todoAdd = function() {
      var input = document.getElementById('todo-input');
      var text  = input.value.trim();
      if (!text) return;
      todos.push({ id: Date.now(), text: text, done: false });
      input.value = '';
      todoRender();
      todoSave();
    };

    function todoToggle(idx) {
      todos[idx].done = !todos[idx].done;
      todoRender();
      todoSave();
    }

    function todoDelete(idx) {
      todos.splice(idx, 1);
      todoRender();
      todoSave();
    }

    window.todoClearDone = function() {
      todos = todos.filter(function(t) { return !t.done; });
      todoRender();
      todoSave();
    };

    document.getElementById('todo-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') todoAdd();
    });

    todoRender();

    // ── Exports ───────────────────────────────────────────────────────
    function mdDownload(filename, content) {
      var blob = new Blob([content], { type: 'text/markdown' });
      var a    = document.createElement('a');
      a.href   = URL.createObjectURL(blob);
      a.download = filename;
      a.click();
      URL.revokeObjectURL(a.href);
    }

    window.exportNotes = function() {
      var text = document.getElementById('notes-area').value.trim();
      if (!text) return;
      mdDownload('notes.md', text);
    };

    window.exportTodos = function() {
      if (!todos.length) return;
      var date  = new Date().toISOString().slice(0, 10);
      var lines = ['# To-Do — ' + date, ''];
      var open  = todos.filter(function(t) { return !t.done; });
      var done  = todos.filter(function(t) { return t.done; });
      open.forEach(function(t) { lines.push('- [ ] ' + t.text); });
      if (open.length && done.length) lines.push('');
      done.forEach(function(t) { lines.push('- [x] ' + t.text); });
      mdDownload('todos-' + date + '.md', lines.join('\n'));
    };
  </script>

</AdminLayout>
