---
/**
 * /orbiter — Admin Dashboard
 * Injected by @orbiter/integration
 */
import { podPath } from 'orbiter:db';
import { openPod } from '@orbiter/core';

const db          = openPod(podPath);
const collections = db.getCollections();
const meta        = {
  siteName: db.getMeta('site.name') ?? 'Orbiter',
  siteUrl:  db.getMeta('site.url')  ?? '',
};

// Stats per collection
const stats = collections.map(col => {
  const all       = db.getEntries(col.id);
  const published = all.filter(e => e.status === 'published').length;
  const drafts    = all.filter(e => e.status === 'draft').length;
  return { ...col, total: all.length, published, drafts, entries: all.slice(0, 5) };
});

const totalEntries = stats.reduce((n, s) => n + s.total, 0);
const totalPublished = stats.reduce((n, s) => n + s.published, 0);

// Recent entries across all collections
const recent = collections
  .flatMap(col => db.getEntries(col.id).map(e => ({ ...e, collectionLabel: col.label })))
  .sort((a, b) => new Date(b.updated_at) - new Date(a.updated_at))
  .slice(0, 8);

// Media count
const mediaCount = db.db.prepare('SELECT COUNT(*) as n FROM _media').get().n;

db.close();
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Orbiter — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #0a0a0f; color: #b8b8d0; font-family: 'DM Mono', monospace; min-height: 100vh; }

    .layout { display: grid; grid-template-columns: 210px 1fr; grid-template-rows: 54px 1fr; min-height: 100vh; }

    /* Topbar */
    .topbar {
      grid-column: 1 / -1;
      background: #12121a;
      border-bottom: 1px solid #1c1c28;
      display: flex; align-items: center;
      padding: 0 22px; gap: 0;
    }
    .logo { font-family: 'Noto Serif JP', serif; font-weight: 200; font-size: 17px; color: #e8e8f2; display: flex; align-items: center; gap: 9px; letter-spacing: 0.1em; }
    .logo-mark { width: 22px; height: 22px; border: 1px solid #c8a86b; display: flex; align-items: center; justify-content: center; font-size: 9px; color: #c8a86b; font-family: 'DM Mono', monospace; }
    .logo-kana { font-size: 10px; color: #3a3a50; font-family: 'Noto Serif JP', serif; margin-left: 2px; }
    .topbar-site { margin-left: 24px; font-size: 11px; color: #3a3a50; }
    .topbar-pod { margin-left: auto; font-size: 10px; color: #3a3a50; display: flex; align-items: center; gap: 6px; }
    .pod-dot { width: 5px; height: 5px; border-radius: 50%; background: #2d8b6a; animation: pulse 2.5s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

    /* Sidebar */
    .sidebar { background: #12121a; border-right: 1px solid #1c1c28; padding: 24px 0; display: flex; flex-direction: column; }
    .nav-section { font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; color: #3a3a50; padding: 0 18px; margin: 20px 0 6px; }
    .nav-section:first-child { margin-top: 0; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 8px 18px; font-size: 11.5px; color: #6868a0; cursor: pointer; position: relative; text-decoration: none; transition: color 0.15s; }
    .nav-item:hover { color: #b8b8d0; background: rgba(255,255,255,0.02); }
    .nav-item.active { color: #e8e8f2; background: rgba(123,140,222,0.06); }
    .nav-item.active::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: #c8a86b; }
    .nav-icon { width: 13px; text-align: center; font-size: 10px; opacity: 0.6; }
    .nav-badge { margin-left: auto; font-size: 9px; background: #1c1c28; color: #6868a0; padding: 1px 6px; border: 1px solid #252535; }
    .sidebar-pod { margin-top: auto; padding: 14px 18px; border-top: 1px solid #1c1c28; font-size: 10px; color: #3a3a50; }
    .sidebar-pod-name { color: #b8b8d0; font-size: 11px; margin-bottom: 3px; display: flex; align-items: center; gap: 5px; }
    .sidebar-pod-name::before { content: '◆'; font-size: 6px; color: #c8a86b; }

    /* Main */
    .main { padding: 32px 40px; background: #0a0a0f; overflow-y: auto; position: relative; }
    .kanji { position: absolute; right: 32px; bottom: 24px; font-family: 'Noto Serif JP', serif; font-size: 130px; color: #e8e8f2; opacity: 0.018; pointer-events: none; }

    .main-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 28px; padding-bottom: 18px; border-bottom: 1px solid #1c1c28; }
    .main-title { font-family: 'Noto Serif JP', serif; font-weight: 200; font-size: 26px; color: #e8e8f2; letter-spacing: 0.05em; }
    .main-title-jp { font-size: 10px; color: #3a3a50; font-family: 'Noto Serif JP', serif; font-weight: 200; letter-spacing: 0.1em; margin-top: 5px; }
    .main-date { font-size: 10px; color: #3a3a50; text-align: right; line-height: 1.9; }

    /* Stats */
    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 28px; }
    .stat { background: #12121a; border: 1px solid #1c1c28; padding: 18px 20px; position: relative; overflow: hidden; transition: border-color 0.2s; }
    .stat:hover { border-color: #c8a86b; }
    .stat-label { font-size: 9px; letter-spacing: 0.28em; text-transform: uppercase; color: #3a3a50; margin-bottom: 8px; }
    .stat-value { font-size: 30px; font-weight: 200; font-family: 'Noto Serif JP', serif; color: #e8e8f2; line-height: 1; margin-bottom: 5px; }
    .stat-sub { font-size: 10px; color: #2d8b6a; }
    .stat-sub.gold { color: #c8a86b; }
    .stat-deco { position: absolute; bottom: 8px; right: 12px; font-family: 'Noto Serif JP', serif; font-size: 26px; opacity: 0.04; color: #e8e8f2; pointer-events: none; }

    /* Content grid */
    .content-grid { display: grid; grid-template-columns: 1fr 280px; gap: 20px; }

    /* Panel */
    .panel { background: #12121a; border: 1px solid #1c1c28; }
    .panel-header { padding: 12px 18px; border-bottom: 1px solid #1c1c28; display: flex; align-items: center; justify-content: space-between; }
    .panel-title { font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: #b8b8d0; display: flex; align-items: center; gap: 8px; }
    .panel-title::before { content: '—'; color: #c8a86b; }
    .panel-action { font-size: 10px; color: #7b8cde; text-decoration: none; }
    .panel-action:hover { color: #e8e8f2; }

    /* Entry rows */
    .entry-row { display: grid; grid-template-columns: 1fr 100px 70px 72px; align-items: center; padding: 11px 18px; border-bottom: 1px solid rgba(255,255,255,0.02); text-decoration: none; transition: background 0.12s; }
    .entry-row:hover { background: rgba(255,255,255,0.02); }
    .entry-row:last-child { border-bottom: none; }
    .entry-title { font-size: 11.5px; color: #b8b8d0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .entry-coll { font-size: 9.5px; color: #3a3a50; margin-top: 2px; }
    .entry-date { font-size: 10px; color: #3a3a50; }
    .pill { font-size: 9px; padding: 2px 7px; text-align: center; }
    .pill.published { color: #2d8b6a; background: rgba(45,139,106,0.1); }
    .pill.draft { color: #c8a86b; background: rgba(200,168,107,0.1); }

    /* Side panels */
    .side-panels { display: flex; flex-direction: column; gap: 14px; }

    .coll-item { display: flex; align-items: center; justify-content: space-between; padding: 12px 18px; border-bottom: 1px solid rgba(255,255,255,0.02); text-decoration: none; transition: background 0.12s; }
    .coll-item:hover { background: rgba(255,255,255,0.02); }
    .coll-item:last-child { border-bottom: none; }
    .coll-name { font-size: 12px; color: #b8b8d0; }
    .coll-counts { font-size: 10px; color: #3a3a50; text-align: right; line-height: 1.8; }
    .coll-counts span { color: #2d8b6a; }

    .new-btn { display: block; margin: 14px 18px 16px; padding: 9px; background: transparent; border: 1px solid #c8a86b; color: #c8a86b; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.14em; cursor: pointer; text-transform: uppercase; text-align: center; text-decoration: none; transition: all 0.2s; }
    .new-btn:hover { background: #c8a86b; color: #0a0a0f; }
  </style>
</head>
<body>
  <div class="layout">

    <!-- Topbar -->
    <div class="topbar">
      <div class="logo">
        <div class="logo-mark">OR</div>
        Orbiter<span class="logo-kana">オービター</span>
      </div>
      <div class="topbar-site">{meta.siteName}</div>
      <div class="topbar-pod">
        <div class="pod-dot"></div>
        pod synced
      </div>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
      <div class="nav-section">Content</div>
      <a href="/orbiter" class="nav-item active"><span class="nav-icon">◈</span>Dashboard</a>
      {collections.map(col => (
        <a href={`/orbiter/${col.id}`} class="nav-item">
          <span class="nav-icon">▤</span>
          {col.label}
          <span class="nav-badge">{stats.find(s => s.id === col.id)?.total ?? 0}</span>
        </a>
      ))}
      <div class="nav-section">Assets</div>
      <a href="/orbiter/media" class="nav-item"><span class="nav-icon">⊞</span>Media<span class="nav-badge">{mediaCount}</span></a>
      <div class="nav-section">System</div>
      <a href="/orbiter/settings" class="nav-item"><span class="nav-icon">◎</span>Settings</a>
      <div class="sidebar-pod">
        <div class="sidebar-pod-name">content.pod</div>
        <div>{totalEntries} entries · {collections.length} collections</div>
      </div>
    </div>

    <!-- Main -->
    <div class="main">
      <div class="kanji">星</div>

      <div class="main-header">
        <div>
          <div class="main-title">Overview</div>
          <div class="main-title-jp">概要 — 管理ダッシュボード</div>
        </div>
        <div class="main-date">
          <div>{new Date().toLocaleDateString('de-AT', { weekday: 'long' })}</div>
          <div>{new Date().toLocaleDateString('de-AT')}</div>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats">
        <div class="stat">
          <div class="stat-label">Total Entries</div>
          <div class="stat-value">{totalEntries}</div>
          <div class="stat-sub">{collections.length} collections</div>
          <div class="stat-deco">文</div>
        </div>
        <div class="stat">
          <div class="stat-label">Published</div>
          <div class="stat-value">{totalPublished}</div>
          <div class="stat-sub">{Math.round(totalPublished / (totalEntries || 1) * 100)}% of total</div>
          <div class="stat-deco">開</div>
        </div>
        <div class="stat">
          <div class="stat-label">Drafts</div>
          <div class="stat-value">{totalEntries - totalPublished}</div>
          <div class="stat-sub gold">unpublished</div>
          <div class="stat-deco">草</div>
        </div>
        <div class="stat">
          <div class="stat-label">Media Assets</div>
          <div class="stat-value">{mediaCount}</div>
          <div class="stat-sub">in .pod file</div>
          <div class="stat-deco">像</div>
        </div>
      </div>

      <!-- Content grid -->
      <div class="content-grid">

        <!-- Recent entries -->
        <div class="panel">
          <div class="panel-header">
            <div class="panel-title">Recent Entries</div>
          </div>
          {recent.map(entry => (
            <a href={`/orbiter/${entry.collection_id}/${entry.slug}`} class="entry-row">
              <div>
                <div class="entry-title">{entry.data?.title ?? entry.slug}</div>
                <div class="entry-coll">{entry.collectionLabel}</div>
              </div>
              <div class="entry-date">{new Date(entry.updated_at).toLocaleDateString('de-AT')}</div>
              <div class={`pill ${entry.status}`}>{entry.status}</div>
            </a>
          ))}
        </div>

        <!-- Side panels -->
        <div class="side-panels">
          <div class="panel">
            <div class="panel-header">
              <div class="panel-title">Collections</div>
            </div>
            {stats.map(col => (
              <a href={`/orbiter/${col.id}`} class="coll-item">
                <div class="coll-name">{col.label}</div>
                <div class="coll-counts">
                  <span>{col.published}</span> published<br/>
                  {col.drafts} draft{col.drafts !== 1 ? 's' : ''}
                </div>
              </a>
            ))}
            <a href="#" class="new-btn">+ New Entry</a>
          </div>
        </div>

      </div>
    </div>

  </div>
</body>
</html>
