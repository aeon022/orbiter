---
/**
 * /orbiter/build — Build trigger page + API endpoint
 * GET  → shows build page
 * POST → triggers webhook (called via fetch from the page)
 */
import { podPath } from 'orbiter:db';
import { openPod } from '@orbiter/core';
import AdminLayout from './AdminLayout.astro';

// ── Handle POST (API) ─────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const db  = openPod(podPath);
  const url = db.getMeta('build.webhook_url') ?? '';

  if (!url) {
    db.close();
    return new Response(JSON.stringify({ ok: false, error: 'No webhook URL configured' }), {
      status: 400,
      headers: { 'Content-Type': 'application/json' },
    });
  }

  try {
    const res = await fetch(url, { method: 'POST' });
    const now = new Date().toISOString().replace('T', ' ').replace(/\.\d{3}Z$/, '');
    db.setMeta('build.last_triggered', now);
    db.setMeta('build.last_status', res.ok ? 'ok' : String(res.status));
    db.close();
    return new Response(JSON.stringify({ ok: res.ok, status: res.status }), {
      headers: { 'Content-Type': 'application/json' },
    });
  } catch (e) {
    db.close();
    return new Response(JSON.stringify({ ok: false, error: e.message }), {
      status: 502,
      headers: { 'Content-Type': 'application/json' },
    });
  }
}

// ── GET ───────────────────────────────────────────────────────────────
const db             = openPod(podPath);
const webhookUrl     = db.getMeta('build.webhook_url') ?? '';
const lastTriggered  = db.getMeta('build.last_triggered') ?? '';
const lastStatus     = db.getMeta('build.last_status') ?? '';
const allCollections = db.getCollections().map(c => ({
  id: c.id, label: c.label, total: db.getEntries(c.id).length,
}));
db.close();

const hasWebhook = webhookUrl.length > 0;
const maskedUrl  = hasWebhook
  ? webhookUrl.replace(/^(https?:\/\/[^/]+\/).*$/, '$1…')
  : '';
---
<style>
  .main-inner { padding:40px; max-width:620px; }
  .main-header { margin-bottom:36px; padding-bottom:20px; border-bottom:1px solid var(--line); }
  .main-title { font-family:var(--serif); font-weight:200; font-size:26px; color:var(--heading); letter-spacing:0.05em; line-height:1; margin-bottom:6px; }
  .main-sub { font-size:10px; color:var(--muted); }

  .trigger-card { background:var(--bg2); border:1px solid var(--line); padding:28px 28px 24px; margin-bottom:16px; }
  .trigger-label { font-size:9px; letter-spacing:0.28em; text-transform:uppercase; color:var(--muted); margin-bottom:16px; display:flex; align-items:center; gap:8px; }
  .trigger-label::before { content:"—"; color:var(--gold); }
  .trigger-url { font-size:11px; color:var(--mid); background:var(--bg0); border:1px solid var(--line); padding:8px 12px; margin-bottom:16px; display:flex; align-items:center; gap:8px; }
  .trigger-url-icon { color:var(--muted); flex-shrink:0; }
  .trigger-url-text { flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .no-webhook { font-size:11px; color:var(--muted); background:var(--gold-bg); border:1px solid var(--gold); padding:10px 14px; margin-bottom:16px; display:flex; align-items:center; gap:8px; }
  .no-webhook a { color:var(--gold); }
  .btn-trigger { display:flex; align-items:center; gap:10px; padding:12px 28px; background:var(--gold); border:none; color:var(--bg0); font-family:var(--mono); font-size:11px; letter-spacing:0.12em; text-transform:uppercase; cursor:pointer; transition:background 0.15s; }
  .btn-trigger:hover:not(:disabled) { background:#7a5520; }
  .btn-trigger:disabled { opacity:0.5; cursor:not-allowed; }
  .btn-trigger-icon { font-size:13px; }

  .status-row { display:flex; align-items:center; gap:10px; margin-top:14px; font-size:10px; color:var(--muted); min-height:20px; }
  .status-dot-build { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
  .status-dot-build.idle    { background:var(--line); }
  .status-dot-build.running { background:var(--gold); animation:pulse 1s ease-in-out infinite; }
  .status-dot-build.ok      { background:var(--jade); }
  .status-dot-build.error   { background:var(--crimson); }

  .history-card { background:var(--bg2); border:1px solid var(--line); padding:20px 28px; }
  .history-row { display:flex; align-items:center; gap:12px; padding:7px 0; border-bottom:1px solid var(--line2); font-size:11px; color:var(--mid); }
  .history-row:last-child { border-bottom:none; }
  .history-status { font-size:9px; padding:2px 7px; border:1px solid currentColor; }
  .history-status.ok    { color:var(--jade); }
  .history-status.error { color:var(--crimson); }
  .history-time { margin-left:auto; font-size:9px; color:var(--muted); }
</style>
<AdminLayout
  title="Build"
  activeNav="build"
  breadcrumbs={[{label:'Dashboard',href:'/orbiter'},{label:'Build'}]}
  collections={allCollections}
  podInfo="deploy config"
>
  <div class="main-inner">
    <div class="main-header">
      <div class="main-title">Build &amp; Deploy</div>
      <div class="main-sub">Rebuild der Website via Webhook auslösen</div>
    </div>

    <!-- Trigger -->
    <div class="trigger-card">
      <div class="trigger-label">Webhook</div>
      {hasWebhook ? (
        <div class="trigger-url">
          <span class="trigger-url-icon">◈</span>
          <span class="trigger-url-text">{maskedUrl}</span>
        </div>
      ) : (
        <div class="no-webhook">
          ◎ Kein Webhook konfiguriert — <a href="/orbiter/settings">in den Einstellungen hinzufügen</a>
        </div>
      )}
      <button class="btn-trigger" id="trigger-btn" onclick="triggerBuild()" {!hasWebhook ? 'disabled' : ''}>
        <span class="btn-trigger-icon">▲</span>
        Build auslösen
      </button>
      <div class="status-row">
        <div class="status-dot-build idle" id="status-dot"></div>
        <span id="status-text">
          {lastTriggered ? `Letzter Build: ${lastTriggered} — ${lastStatus === 'ok' ? 'erfolgreich' : lastStatus || '—'}` : 'Noch kein Build ausgelöst'}
        </span>
      </div>
    </div>

    {lastTriggered && (
      <div class="history-card">
        <div class="trigger-label">Verlauf</div>
        <div class="history-row">
          <span class={`history-status ${lastStatus === 'ok' ? 'ok' : 'error'}`}>{lastStatus === 'ok' ? 'erfolgreich' : 'fehler'}</span>
          <span>manuell ausgelöst</span>
          <span class="history-time">{lastTriggered}</span>
        </div>
      </div>
    )}
  </div>
</AdminLayout>
<script>
  window.triggerBuild = async function() {
    const btn  = document.getElementById('trigger-btn');
    const dot  = document.getElementById('status-dot');
    const text = document.getElementById('status-text');

    btn.disabled = true;
    dot.className  = 'status-dot-build running';
    text.textContent = 'Build wird ausgelöst…';

    try {
      const res  = await fetch('/orbiter/build', { method: 'POST' });
      const json = await res.json();

      if (json.ok) {
        dot.className    = 'status-dot-build ok';
        text.textContent = 'Build erfolgreich ausgelöst — ' + new Date().toLocaleTimeString('de');
      } else {
        dot.className    = 'status-dot-build error';
        text.textContent = 'Fehler: ' + (json.error ?? `HTTP ${json.status}`);
        btn.disabled = false;
      }
    } catch (e) {
      dot.className    = 'status-dot-build error';
      text.textContent = 'Netzwerkfehler: ' + e.message;
      btn.disabled = false;
    }
  };
</script>
