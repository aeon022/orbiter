---
import { podPath } from 'orbiter:db';
import { openPod } from '@orbiter/core';
import AdminLayout from './AdminLayout.astro';

// ── Handle POST (save) ────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const db   = openPod(podPath);

  const fields = ['site.name', 'site.url', 'site.description', 'site.locale', 'site.locales', 'build.webhook_url'];
  for (const key of fields) {
    const val = form.get(key)?.toString() ?? '';
    db.setMeta(key, val);
  }

  db.close();
  return Astro.redirect('/orbiter/settings?saved=1');
}

// ── GET ───────────────────────────────────────────────────────────────
const db      = openPod(podPath);
const meta    = {
  name:        db.getMeta('site.name')        ?? '',
  url:         db.getMeta('site.url')         ?? '',
  description: db.getMeta('site.description') ?? '',
  locale:      db.getMeta('site.locale')      ?? '',
  locales:     db.getMeta('site.locales')     ?? '',
  webhookUrl:  db.getMeta('build.webhook_url') ?? '',
};
const formatVersion = db.getMeta('format_version') ?? '1';
const allCollections = db.getCollections().map(c => ({
  id: c.id, label: c.label, total: db.getEntries(c.id).length,
}));
db.close();

const saved = Astro.url.searchParams.get('saved') === '1';
---
<style>
  .main-inner { padding:32px 40px; max-width:680px; }
  .main-header { display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:32px; padding-bottom:18px; border-bottom:1px solid var(--line); }
  .main-title { font-family:var(--serif); font-weight:200; font-size:26px; color:var(--heading); letter-spacing:0.05em; line-height:1; }

  .settings-group { background:var(--bg2); border:1px solid var(--line); margin-bottom:14px; }
  .group-header { padding:10px 18px; border-bottom:1px solid var(--line); font-size:9px; letter-spacing:0.28em; text-transform:uppercase; color:var(--muted); display:flex; align-items:center; gap:8px; }
  .group-header::before { content:"—"; color:var(--gold); }
  .setting-row { display:grid; grid-template-columns:1fr 260px; align-items:center; gap:20px; padding:14px 18px; border-bottom:1px solid var(--line2); }
  .setting-row:last-child { border-bottom:none; }
  .setting-label { font-size:12px; color:var(--text); margin-bottom:2px; }
  .setting-desc { font-size:10px; color:var(--muted); }

  .save-row { display:flex; justify-content:flex-end; margin-top:8px; }
  .btn-save { padding:9px 24px; background:var(--gold); border:1px solid var(--gold); color:var(--bg0); font-family:var(--mono); font-size:10px; letter-spacing:0.12em; text-transform:uppercase; cursor:pointer; transition:all 0.15s; }
  .btn-save:hover { background:#7a5520; border-color:#7a5520; }

  .field-input, .field-select { width:100%; background:var(--bg0); border:1px solid var(--line); padding:7px 9px; color:var(--heading); font-family:var(--mono); font-size:11px; outline:none; appearance:none; transition:border-color 0.15s; }
  .field-input:focus, .field-select:focus { border-color:var(--accent); }
  .field-input[readonly] { color:var(--muted); cursor:default; }

  .saved-banner { background:var(--jade-bg); border-bottom:1px solid rgba(30,107,80,0.15); padding:7px 40px; font-size:10px; color:var(--jade); display:flex; align-items:center; gap:6px; letter-spacing:0.04em; }
  .saved-banner::before { content:"✓"; }
</style>
<AdminLayout
  title="Settings"
  activeNav="settings"
  breadcrumbs={[{label:'Dashboard',href:'/orbiter'},{label:'Settings'}]}
  collections={allCollections}
  podInfo={`v${formatVersion} format`}
>
  {saved && <div class="saved-banner">Einstellungen gespeichert</div>}

  <div class="main-inner">
    <div class="main-header">
      <div class="main-title">Settings</div>
    </div>

    <form method="POST">
      <!-- Site -->
      <div class="settings-group">
        <div class="group-header">Site</div>
        <div class="setting-row">
          <div>
            <div class="setting-label">Site Name</div>
            <div class="setting-desc">Wird im Admin-Header angezeigt</div>
          </div>
          <input class="field-input" name="site.name" value={meta.name} placeholder="Meine Website" />
        </div>
        <div class="setting-row">
          <div>
            <div class="setting-label">Site URL</div>
            <div class="setting-desc">Für Vorschau-Links</div>
          </div>
          <input class="field-input" name="site.url" value={meta.url} placeholder="https://example.com" />
        </div>
        <div class="setting-row">
          <div>
            <div class="setting-label">Beschreibung</div>
            <div class="setting-desc">Kurze Website-Beschreibung</div>
          </div>
          <input class="field-input" name="site.description" value={meta.description} placeholder="Eine kurze Beschreibung" />
        </div>
        <div class="setting-row">
          <div>
            <div class="setting-label">Standard-Sprache</div>
            <div class="setting-desc">Primärer Sprachcode (z. B. de, en)</div>
          </div>
          <input class="field-input" name="site.locale" value={meta.locale} placeholder="de" />
        </div>
        <div class="setting-row">
          <div>
            <div class="setting-label">Alle Sprachen</div>
            <div class="setting-desc">Kommagetrennt — wird via orbiter:collections exportiert</div>
          </div>
          <input class="field-input" name="site.locales" value={meta.locales} placeholder="de,en" />
        </div>
      </div>

      <!-- Build -->
      <div class="settings-group">
        <div class="group-header">Build &amp; Deploy</div>
        <div class="setting-row">
          <div>
            <div class="setting-label">Webhook URL</div>
            <div class="setting-desc">POST-Ziel für Build-Trigger (Netlify, Vercel, …)</div>
          </div>
          <input class="field-input" name="build.webhook_url" value={meta.webhookUrl} placeholder="https://api.netlify.com/build/hook/…" />
        </div>
      </div>

      <div class="save-row">
        <button type="submit" class="btn-save">Einstellungen speichern</button>
      </div>
    </form>

    <!-- Pod info (readonly) -->
    <div class="settings-group">
      <div class="group-header">Pod</div>
      <div class="setting-row">
        <div>
          <div class="setting-label">Pod-Pfad</div>
          <div class="setting-desc">Speicherort der .pod-Datei</div>
        </div>
        <input class="field-input" value={podPath} readonly />
      </div>
      <div class="setting-row">
        <div>
          <div class="setting-label">Format-Version</div>
          <div class="setting-desc">Schema-Version</div>
        </div>
        <input class="field-input" value={`v${formatVersion}`} readonly />
      </div>
      {allCollections.map(c => (
        <div class="setting-row">
          <div>
            <div class="setting-label">{c.label}</div>
            <div class="setting-desc">collection · id: {c.id}</div>
          </div>
          <input class="field-input" value={`${c.total} Einträge`} readonly />
        </div>
      ))}
    </div>
  </div>
</AdminLayout>
