---
import { podPath } from 'orbiter:db';
import { openPod, verifyPassword, generateToken } from '@orbiter/core';
import adminUtils from 'orbiter:admin-utils';
import { useTranslations } from '../src/i18n.js';

// Already logged in? → redirect
const existingToken = Astro.cookies.get('orb_sess')?.value;
if (existingToken) {
  const _db = openPod(podPath);
  const _u  = _db.checkSession(existingToken);
  _db.close();
  if (_u) return Astro.redirect('/orbiter');
}

let error = '';

if (Astro.request.method === 'POST') {
  const form     = await Astro.request.formData();
  const username = form.get('username')?.toString().trim() ?? '';
  const password = form.get('password')?.toString() ?? '';

  const db   = openPod(podPath);
  const user = db.getUserByUsername(username);
  const valid = user ? await verifyPassword(password, user.password) : false;

  if (valid) {
    const token     = generateToken();
    const expiresAt = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000)
      .toISOString().replace('T', ' ').replace(/\.\d{3}Z$/, '');
    db.createSession(user.id, token, expiresAt);
    db.close();
    Astro.cookies.set('orb_sess', token, {
      httpOnly: true,
      sameSite: 'lax',
      path:     '/',
      maxAge:   7 * 24 * 60 * 60,
    });
    return Astro.redirect('/orbiter');
  }

  db.close();
  error = 'login_error';
}

const locale = Astro.cookies.get('orb_locale')?.value ?? 'en';
const t = useTranslations(locale);
---
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg0:#f5f2ec; --bg1:#faf8f3; --bg2:#ffffff; --bg3:#edeae3;
    --line:#e0dbd0; --line2:rgba(0,0,0,0.04);
    --muted:#a09890; --mid:#706860; --text:#3a3228; --heading:#1a1510;
    --gold:#9a6e30; --gold-bg:rgba(154,110,48,0.08);
    --jade:#1e6b50; --jade-bg:rgba(30,107,80,0.07);
    --accent:#3d4fa8; --crimson:#8b2635; --crimson-bg:rgba(139,38,53,0.07);
    --serif:"Noto Serif JP",serif; --mono:"DM Mono",monospace;
  }
  html.dark {
    --bg0:#0f0f14; --bg1:#14141a; --bg2:#1c1c24; --bg3:#22222d;
    --line:#2a2a3a; --line2:rgba(255,255,255,0.04);
    --muted:#52526e; --mid:#8080a0; --text:#b0b0cc; --heading:#e0e0f0;
    --gold:#c8a86b; --gold-bg:rgba(200,168,107,0.08);
    --jade:#2d8b6a; --jade-bg:rgba(45,139,106,0.08);
    --accent:#7a8fd4; --crimson:#c0525e; --crimson-bg:rgba(192,82,94,0.08);
  }
  html, body { background:var(--bg0); color:var(--text); font-family:var(--mono); font-size:13px; line-height:1.6; min-height:100vh; -webkit-font-smoothing:antialiased; }
  .login-wrap { display:flex; align-items:center; justify-content:center; min-height:100vh; padding:24px; }
  .login-card { background:var(--bg2); border:1px solid var(--line); width:100%; max-width:340px; }
  .login-head { padding:28px 28px 20px; border-bottom:1px solid var(--line); }
  .logo { display:flex; align-items:center; gap:10px; text-decoration:none; margin-bottom:18px; }
  .logo-mark { width:24px; height:24px; border:1px solid var(--gold); display:flex; align-items:center; justify-content:center; font-size:9px; color:var(--gold); font-family:var(--mono); }
  .logo-name { font-family:var(--serif); font-weight:200; font-size:18px; color:var(--heading); letter-spacing:0.1em; }
  .login-title { font-size:10px; letter-spacing:0.24em; text-transform:uppercase; color:var(--muted); }
  .login-body { padding:24px 28px 28px; }
  .field { margin-bottom:16px; }
  .field:last-of-type { margin-bottom:20px; }
  .field label { display:block; font-size:9px; letter-spacing:0.2em; text-transform:uppercase; color:var(--muted); margin-bottom:6px; }
  .field input { width:100%; background:var(--bg0); border:1px solid var(--line); padding:8px 10px; color:var(--heading); font-family:var(--mono); font-size:12px; outline:none; transition:border-color 0.15s; }
  .field input:focus { border-color:var(--accent); }
  .btn-login { width:100%; padding:11px; background:var(--gold); border:1px solid var(--gold); color:var(--bg0); font-family:var(--mono); font-size:10px; letter-spacing:0.14em; text-transform:uppercase; cursor:pointer; transition:background 0.15s; }
  .btn-login:hover { background:#7a5520; border-color:#7a5520; }
  .error-msg { margin-top:12px; padding:8px 10px; background:var(--crimson-bg); border:1px solid rgba(139,38,53,0.15); font-size:10px; color:var(--crimson); display:flex; align-items:center; gap:6px; }
  .error-msg::before { content:"✕"; }
  .dark-toggle { position:fixed; top:16px; right:16px; background:none; border:1px solid var(--line); color:var(--mid); font-family:var(--mono); font-size:10px; padding:3px 10px; cursor:pointer; transition:color 0.12s,border-color 0.12s; }
  .dark-toggle:hover { color:var(--heading); border-color:var(--mid); }
</style>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' fill='%23f5f2ec'/><rect x='5' y='5' width='22' height='22' fill='none' stroke='%239a6e30' stroke-width='1.5'/><text x='16' y='21' font-family='monospace' font-size='11' fill='%239a6e30' text-anchor='middle'>OR</text></svg>" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Orbiter — Login</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200;300&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
</head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <div class="login-head">
        <a href="/orbiter/login" class="logo">
          <div class="logo-mark">OR</div>
          <span class="logo-name">Orbiter</span>
        </a>
        <div class="login-title">{t.login_title}</div>
      </div>
      <div class="login-body">
        <form method="POST">
          <div class="field">
            <label for="username">{t.login_username}</label>
            <input type="text" id="username" name="username" autocomplete="username" autofocus required />
          </div>
          <div class="field">
            <label for="password">{t.login_password}</label>
            <input type="password" id="password" name="password" autocomplete="current-password" required />
          </div>
          <button type="submit" class="btn-login">{t.login_submit}</button>
          {error && <div class="error-msg">{t.login_error}</div>}
        </form>
      </div>
    </div>
  </div>
  <button id="orb-dark-btn" onclick="__orbToggleDark()" class="dark-toggle" title="Toggle dark mode">● {t.nav_dark}</button>
  <script set:html={adminUtils} is:inline></script>
</body>
</html>
