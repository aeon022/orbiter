{
  "name": "@a83/orbiter-desktop",
  "version": "0.2.0",
  "description": "Orbiter CMS — Desktop App",
  "author": "Gerwin Weiher <gerwin.weiher@gmail.com>",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win"
  },
  "dependencies": {
    "@a83/orbiter-core": "*",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@hono/node-server": "^1.14.4",
    "basic-ftp": "^5.0.5",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "hono": "^4.7.11",
    "nodemailer": "^8.0.10",
    "sharp": "^0.34.5",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "electron": "42.4.1",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "sh.orbiter.desktop",
    "productName": "Orbiter",
    "electronVersion": "42.4.1",
    "publish": {
      "provider": "github",
      "owner": "aeon022",
      "repo": "orbiter"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*"
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      {
        "from": "../../packages/admin/src",
        "to": "admin/src"
      },
      {
        "from": "../../packages/admin/public",
        "to": "admin/public"
      },
      {
        "from": "../../packages/admin",
        "to": "admin",
        "filter": [
          "package.json"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "dmg": {
      "title": "Orbiter ${version}",
      "background": "assets/dmg-background.png",
      "iconSize": 80,
      "iconTextSize": 12,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 160,
          "type": "file"
        },
        {
          "x": 390,
          "y": 160,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
