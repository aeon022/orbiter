---
/**
 * Content Layer demo — uses astro:content instead of orbiter:collections.
 * Both work side by side. This page demonstrates the standard Astro API.
 */
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const pages = await getCollection('pages');
const events = await getCollection('events');
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Content Layer Demo — Orbiter</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 720px; margin: 40px auto; padding: 0 20px; color: #1c1917; line-height: 1.6; }
    h1 { font-size: 28px; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 8px; }
    .sub { color: #78716c; font-size: 14px; margin-bottom: 32px; }
    .sub code { background: #f5f5f4; padding: 1px 6px; border-radius: 4px; font-size: 13px; }
    h2 { font-size: 18px; font-weight: 700; margin: 32px 0 12px; color: #44403c; }
    ul { list-style: none; padding: 0; }
    li { padding: 10px 0; border-bottom: 1px solid #f0efed; display: flex; justify-content: space-between; align-items: baseline; }
    li:last-child { border-bottom: none; }
    a { color: #6d28d9; text-decoration: none; font-weight: 500; }
    a:hover { text-decoration: underline; }
    .slug { color: #a8a29e; font-size: 12px; font-family: ui-monospace, monospace; }
    .count { font-size: 12px; color: #a8a29e; margin-left: 4px; }
    .badge { font-size: 10px; background: #ede9fe; color: #6d28d9; padding: 2px 8px; border-radius: 10px; font-weight: 600; }
  </style>
</head>
<body>
  <h1>Content Layer Demo</h1>
  <p class="sub">Loaded via <code>astro:content</code> + <code>orbiterLoader()</code> — not <code>orbiter:collections</code>.</p>

  <h2>Posts <span class="count">({posts.length})</span></h2>
  <ul>
    {posts.map(post => (
      <li>
        <a href={`/cl/${post.id}`}>{post.data.title || post.id}</a>
        <span class="slug">{post.id}</span>
      </li>
    ))}
  </ul>

  <h2>Pages <span class="count">({pages.length})</span></h2>
  <ul>
    {pages.map(page => (
      <li>
        <span>{page.data.title || page.id}</span>
        <span class="slug">{page.id}</span>
      </li>
    ))}
  </ul>

  <h2>Events <span class="count">({events.length})</span></h2>
  <ul>
    {events.map(event => (
      <li>
        <span>{event.data.title || event.id}</span>
        <span class="badge">{event.data.date_start || ''}</span>
      </li>
    ))}
  </ul>
</body>
</html>
