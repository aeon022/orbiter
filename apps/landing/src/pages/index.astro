  <!-- HOW IT WORKS -->
  <section id="how-it-works">
    <h2 class="reveal">How it works</h2>
    <p class="section-lead reveal reveal-delay-1">Your entire CMS lives next to your source code — in one file.</p>

    <div class="file-visual reveal reveal-delay-2">
      <span class="dim">your-site/</span><br />
      <span class="dim">├── astro.config.mjs</span><br />
      <div class="file-highlight">
        ├── content.pod &nbsp;&nbsp;<span class="acc">← your entire CMS</span>
