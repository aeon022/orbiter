<script>
const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

// ── STARFIELD ──────────────────────────────────────────────
const canvas = document.getElementById('starfield') as HTMLCanvasElement;
const ctx    = canvas.getContext('2d')!;

interface Star {
  x: number; y: number;
  r: number;
  vx: number; vy: number;
  base: number;
  phase: number;
  speed: number;
}

let W = 0, H = 0;
let stars: Star[] = [];

function resize() {
  W = canvas.width  = window.innerWidth;
  H = canvas.height = window.innerHeight;
}

function initStars(n = 160) {
  stars = Array.from({ length: n }, () => ({
    x:     Math.random() * W,
    y:     Math.random() * H,
    r:     Math.random() * 1.4 + 0.3,
    vx:    (Math.random() - 0.5) * 0.12,
    vy:    (Math.random() - 0.5) * 0.12,
    base:  Math.random() * 0.55 + 0.15,
    phase: Math.random() * Math.PI * 2,
    speed: Math.random() * 0.018 + 0.004,
  }));
}

function drawStars() {
  ctx.clearRect(0, 0, W, H);
  for (const s of stars) {
    s.phase += s.speed;
    const a = s.base + Math.sin(s.phase) * 0.18;
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(210,215,255,${a})`;
    ctx.fill();
    s.x += s.vx;
    s.y += s.vy;
    if (s.x < -2)  s.x = W + 2;
    if (s.x > W+2) s.x = -2;
    if (s.y < -2)  s.y = H + 2;
    if (s.y > H+2) s.y = -2;
  }
  requestAnimationFrame(drawStars);
}

if (!reducedMotion) {
  resize();
  initStars();
  drawStars();
  window.addEventListener('resize', () => { resize(); initStars(); });
}

// ── HERO PARALLAX + TILT ───────────────────────────────────
const heroInner    = document.querySelector('.hero-inner')         as HTMLElement;
const orbitWrap    = document.querySelector('.orbit-wrap')         as HTMLElement;
const heroEl       = document.querySelector('.hero')               as HTMLElement;
const previewFrame = document.querySelector('.hero-preview-frame') as HTMLElement;

const TILT_MAX    = 18;    // initial rotateX (deg)
const SCALE_START = 0.88;  // image scale at rest (tilted)
const SCALE_END   = 1.06;  // image scale when flat (zoomed in)
const TILT_END    = 720;   // scroll px over which tilt+zoom animate

function updateParallax() {
  const scrollY    = window.scrollY;
  const heroHeight = heroEl.offsetHeight;

  // ── image: tilt unwinds, scale zooms in ───────────────────
  if (previewFrame) {
    const p     = Math.min(1, scrollY / TILT_END);
    const tiltX = TILT_MAX * (1 - p);
    const scale = SCALE_START + (SCALE_END - SCALE_START) * p;
    previewFrame.style.transform = `rotateX(${tiltX}deg) scale(${scale})`;
  }

  // ── text: parallax drift + slow fade ──────────────────────
  if (scrollY > heroHeight + 200) return;
  const progress = scrollY / heroHeight;
  heroInner.style.transform = `translateY(${scrollY * 0.28}px)`;
  // fade starts later (at 50% of hero height) and ends at 130%
  heroInner.style.opacity = String(Math.max(0, 1 - Math.max(0, progress - 0.5) * 2.2));
  orbitWrap.style.transform = `translate(-50%, -54%) translateY(${scrollY * 0.1}px)`;
}

if (!reducedMotion) {
  window.addEventListener('scroll', updateParallax, { passive: true });
}

// ── SCROLL REVEAL ──────────────────────────────────────────
const revealObserver = new IntersectionObserver(
  (entries) => entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      revealObserver.unobserve(e.target);
    }
  }),
  { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
);

document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

// ── SCREENSHOT GALLERY ─────────────────────────────────────
const mainImg     = document.getElementById('ss-main-img')     as HTMLImageElement;
const mainCaption = document.getElementById('ss-main-caption') as HTMLElement;
const mainFrame   = document.getElementById('ss-main-frame')   as HTMLElement;
const thumbs      = document.querySelectorAll<HTMLButtonElement>('.screenshot-thumb');

function setActive(btn: HTMLButtonElement) {
  thumbs.forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
}

function switchScreenshot(btn: HTMLButtonElement) {
  const src     = btn.dataset.src!;
  const caption = btn.dataset.caption!;
  if (mainImg.src.endsWith(src)) return;

  mainFrame.classList.add('ss-fade');
  setTimeout(() => {
    mainImg.src            = src;
    mainImg.alt            = caption;
    mainCaption.textContent = caption;
    mainFrame.classList.remove('ss-fade');
  }, 180);

  setActive(btn);
}

thumbs.forEach(btn => btn.addEventListener('click', () => switchScreenshot(btn)));
if (thumbs[0]) thumbs[0].classList.add('active');

// ── ACTIVE NAV ─────────────────────────────────────────────
const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-section]');
const sections = ['how-it-works', 'features', 'comparison', 'pricing', 'faq', 'tradeoffs']
  .map(id => document.getElementById(id))
  .filter(Boolean) as HTMLElement[];

const sectionObserver = new IntersectionObserver(
  (entries) => entries.forEach(e => {
    if (e.isIntersecting) {
      const id = e.target.id;
      navLinks.forEach(a => a.classList.toggle('active', a.dataset.section === id));
    }
  }),
  { threshold: 0.25 }
);

sections.forEach(s => sectionObserver.observe(s));

// ── SCROLL PROGRESS BAR ────────────────────────────────────
const progressBar = document.getElementById('scroll-progress') as HTMLDivElement;

function updateProgress() {
  const scrolled = window.scrollY;
  const total    = document.documentElement.scrollHeight - window.innerHeight;
  const pct      = total > 0 ? (scrolled / total) * 100 : 0;
  progressBar.style.width = `${pct}%`;
  progressBar.classList.toggle('visible', scrolled > 80);
}

// ── NAV SCROLL STATE ───────────────────────────────────────
const nav = document.querySelector('nav') as HTMLElement;

function updateScroll() {
  nav.classList.toggle('scrolled', window.scrollY > 60);
  updateProgress();
  updateParallax();
}

window.addEventListener('scroll', updateScroll, { passive: true });

// ── BACK TO TOP ────────────────────────────────────────────
const topBtn = document.getElementById('back-to-top') as HTMLButtonElement;

window.addEventListener('scroll', () => {
  topBtn.classList.toggle('visible', window.scrollY > 400);
}, { passive: true });

// ── SMOOTH SCROLL (unified, cancellable) ───────────────────
function easeInOutCubic(t: number) {
  return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
}

let scrollRaf: number | null = null;

function smoothScrollTo(targetY: number) {
  // cancel any running scroll animation
  if (scrollRaf !== null) { cancelAnimationFrame(scrollRaf); scrollRaf = null; }

  const start    = window.scrollY;
  const distance = targetY - start;
  if (Math.abs(distance) < 2) return;

  const duration  = Math.min(900, Math.max(380, Math.abs(distance) * 0.4));
  const startTime = performance.now();

  function step(now: number) {
    const elapsed  = now - startTime;
    const progress = Math.min(elapsed / duration, 1);
    window.scrollTo(0, start + distance * easeInOutCubic(progress));
    if (progress < 1) { scrollRaf = requestAnimationFrame(step); }
    else { scrollRaf = null; }
  }

  scrollRaf = requestAnimationFrame(step);
}

// cancel custom animation on user-initiated wheel/touch so it doesn't fight
window.addEventListener('wheel',      () => { if (scrollRaf) { cancelAnimationFrame(scrollRaf); scrollRaf = null; } }, { passive: true });
window.addEventListener('touchstart', () => { if (scrollRaf) { cancelAnimationFrame(scrollRaf); scrollRaf = null; } }, { passive: true });

topBtn.addEventListener('click', () => {
  topBtn.classList.add('launching');
  setTimeout(() => topBtn.classList.remove('launching'), 220);
  smoothScrollTo(0);
});

// ── ANCHOR SCROLL + SECTION FLASH ──────────────────────────
document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const id     = a.getAttribute('href')!.slice(1);
    const target = id === 'top' ? null : document.getElementById(id);

    e.preventDefault();

    if (!id || id === 'top') {
      smoothScrollTo(0);
      history.pushState(null, '', '/');
      return;
    }

    if (!target) return;

    // account for fixed nav height (scroll-margin-top is set in CSS as well)
    const navH = (document.querySelector('nav') as HTMLElement)?.offsetHeight ?? 80;
    const targetY = target.getBoundingClientRect().top + window.scrollY - navH - 16;
    smoothScrollTo(targetY);
    history.pushState(null, '', `#${id}`);

    setTimeout(() => {
      target.classList.add('section-flash');
      target.addEventListener('animationend', () => target.classList.remove('section-flash'), { once: true });
    }, 550);
  });
});


// ── FAQ ACCORDION ──────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('.faq-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const item   = btn.closest('.faq-item') as HTMLElement;
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(el => {
      el.classList.remove('open');
      el.querySelector<HTMLButtonElement>('.faq-toggle')?.setAttribute('aria-expanded', 'false');
    });
    if (!isOpen) {
      item.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    }
  });
});

// ── COPY BUTTONS ───────────────────────────────────────────
const COPY_ICON  = '<rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>';
const CHECK_ICON = '<polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>';

document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    // data-copy wins; code-copy-btn falls back to sibling <pre> text
    const text = btn.dataset.copy
      ?? btn.closest('.code-block')?.querySelector('pre')?.textContent?.trim()
      ?? '';
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      btn.classList.add('copied');
      btn.querySelector('svg')!.innerHTML = CHECK_ICON;
      setTimeout(() => {
        btn.classList.remove('copied');
        btn.querySelector('svg')!.innerHTML = COPY_ICON;
      }, 1800);
    } catch (_) {}
  });
});

// ── MOBILE HAMBURGER ───────────────────────────────────────
const hamburger   = document.querySelector<HTMLButtonElement>('.nav-hamburger')!;
const mobileMenu  = document.getElementById('mobile-menu')!;

function openMenu() {
  hamburger.setAttribute('aria-expanded', 'true');
  mobileMenu.classList.add('is-open');
  mobileMenu.setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
}

function closeMenu() {
  hamburger.setAttribute('aria-expanded', 'false');
  mobileMenu.classList.remove('is-open');
  mobileMenu.setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
}

hamburger.addEventListener('click', () => {
  hamburger.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
});

// close on any link click inside mobile menu
mobileMenu.querySelectorAll('a').forEach(a => {
  a.addEventListener('click', () => closeMenu());
});

// close on Escape
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeMenu();
});
</script>
