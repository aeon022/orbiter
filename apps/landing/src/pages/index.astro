---
import '../styles/landing.css';
import FooterSignature from '../components/FooterSignature.astro';
import CookieBanner from '../components/CookieBanner.astro';
const features = [
  {
    icon: '◈',
    title: 'One file. Everything.',
    body: 'Content, media, schema, users, sessions — all in a single <code>.pod</code> file. Copy it anywhere. Back it up with <code>cp</code>.',
  },
  {
    icon: '⬡',
    title: 'Astro-native',
    body: 'One line in <code>astro.config.mjs</code> injects a full admin UI at <code>/orbiter</code> via <code>injectRoute</code>. Nothing added to <code>src/pages</code>.',
  },
  {
    icon: '⌗',
    title: 'Familiar content API',
    body: 'Read content with <code>getCollection</code> and <code>getEntry</code> — same shape as Astro\'s built-in content collections.',
  },
  {
    icon: '▦',
    title: 'Schema editor',
    body: 'Add or change fields in the admin without writing migrations. Changes apply immediately.',
  },
  {
    icon: '◫',
    title: 'Media library',
    body: 'Images and files stored as BLOBs directly in the pod. No CDN to configure, no broken paths after deploy.',
  },
  {
    icon: '⟳',
    title: 'Version history',
    body: 'Every publish creates a snapshot. Roll back to any previous version of any entry.',
  },
  {
    icon: '⊞',
    title: 'JSON API',
    body: '<code>GET /orbiter/api/[collection]</code> — optional Bearer token, ready to use from any frontend.',
  },
  {
    icon: '⇅',
    title: 'GitHub sync',
    body: 'On serverless platforms like Netlify and Vercel, pack your pod into a git commit and trigger a rebuild. No data loss between deploys.',
  },
  {
    icon: '↓',
    title: 'Import',
    body: 'Migrate from WordPress (WXR export) or bring in Markdown files. Done in the admin, no CLI needed.',
  },
];

const tradeoffs = [
  {
    title: 'Not for large media libraries',
    body: 'SQLite BLOB storage is convenient for content sites but not for thousands of high-res images. If your media library is in the gigabytes, this isn\'t the right tool.',
  },
  {
    title: 'Serverless requires extra steps',
    body: 'Netlify and Vercel don\'t persist filesystem writes between deploys. The GitHub sync mode works around this, but it adds steps. A VPS or Coolify gives you a better experience.',
  },
  {
    title: 'Built for small teams',
    body: 'Two people editing the same entry at the same moment will get last-write-wins. Fine for a team of 1–5. Not designed for large editorial teams working in parallel.',
  },
];
