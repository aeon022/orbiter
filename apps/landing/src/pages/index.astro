---
import '../styles/landing.css';
import FooterSignature from '../components/FooterSignature.astro';
import CookieBanner from '../components/CookieBanner.astro';
import PageTransition from '../components/PageTransition.astro';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

const _aiMdRaw = readFileSync(new URL('../../../../AI_SETUP.md', import.meta.url), 'utf-8');
const _aiMatch = _aiMdRaw.match(/^```\n([\s\S]+)\n```\s*$/m);
const aiPromptText = _aiMatch ? _aiMatch[1] : _aiMdRaw;

const features = [
  { icon: '◈', title: 'One file. Everything.',        body: 'Content, media, schema, users, sessions — all in a single POD (a SQLite database with a <code>.pod</code> extension). Copy it anywhere. Back it up with <code>cp</code>.' },
  { icon: '⬡', title: 'Astro-native',                 body: 'One line in <code>astro.config.mjs</code> gives you <code>orbiter:collections</code> — a Vite virtual module that snapshots your published content at build time. Zero runtime fetch.' },
  { icon: '⌗', title: 'Familiar content API',         body: 'Read content with <code>getCollection</code> and <code>getEntry</code> — same shape as Astro\'s built-in content collections.' },
  { icon: '⬢', title: 'Content Layer loader',         body: '<code>orbiterLoader()</code> plugs directly into Astro\'s Content Layer API. Use <code>astro:content</code> with auto-generated Zod schemas, incremental builds, and hot reload when the pod changes.' },
  { icon: '▦', title: 'Schema editor',                body: 'Add or change fields without migrations. Export and import schemas as JSON to copy them between collections or pods.' },
  { icon: '◫', title: 'Media library',                body: 'Upload, browse, and manage files. Images are automatically resized and compressed on upload. Four storage backends: pod BLOB, local disk, GitHub CDN, or external URL.' },
  { icon: '⟳', title: 'Version history',              body: 'Every save creates a snapshot, capped at 20 per entry. Restore any previous version with one click from the editor sidebar.' },
  { icon: '⊞', title: 'JSON API + RSS/Sitemap',       body: '<code>GET /orbiter/api/[collection]</code> — optional Bearer token. Plus auto-generated RSS 2.0 feeds and an XML sitemap. All injected, no config.' },
  { icon: '⇅', title: 'Git sync mode',                 body: '<code>orbiter unpack</code> extracts media BLOBs to files, <code>orbiter pack</code> restores them. Commit your pod + media to Git — a GitHub Actions template is included for automatic rebuilds.' },
  { icon: '🗓', title: 'Scheduled publishing',        body: 'Set a <code>publish_at</code> date on any entry. The server auto-publishes and fires the build webhook at the right time. Set <code>unpublish_at</code> to expire content.' },
  { icon: '💬', title: 'Editorial comments',          body: 'Per-entry comment thread in the editor. Post, resolve, delete. Optional email notification on new comments via SMTP.' },
  { icon: '⌘', title: 'Command palette',              body: '<code>⌘K</code> fuzzy search across all content and navigation. Installable as a PWA on mobile and desktop.' },
  { icon: '👥', title: 'Multi-user & roles',           body: 'Admin and editor roles. Entry locking warns when two editors open the same entry simultaneously. Manage users in the UI.' },
  { icon: '⌾', title: 'Multilingual (i18n)',           body: 'Per-entry locale variants — same slug, separate locale columns. Configure locales in Settings, translate entries via locale tabs in the editor. <code>getLocaleCollection()</code> and <code>getLocaleEntry()</code> with automatic fallback.' },
  { icon: '◉', title: 'Space Station mode',           body: 'A distinct layout with a floating magnification dock, command palette (<code>⌘K</code>), vim keyboard navigation, HUD panel, notification center, zen mode, and a full mobile tab-bar. Three themes × two colour schemes.' },
  { icon: '⊡', title: 'Trash & restore',              body: 'Deleted entries move to a recoverable Trash tab. Restore to draft or permanently delete. Bulk restore and bulk purge. Activity log records every action with actor and timestamp.' },
  { icon: '◎', title: 'Draft preview',                body: 'Generate a preview token in Settings → API. Attach it to your preview URL — <code>getPreviewEntry()</code> reads any draft directly from the pod, bypassing the published snapshot.' },
  { icon: '✉', title: 'Form inbox',                   body: 'Receive contact and booking form submissions from your Astro site via <code>POST /api/form/:formId</code>. View, filter, reply by email, and mark as confirmed, rejected, or done — all from the admin UI.' },
  { icon: '◉', title: 'Built-in SEO',                 body: 'Every entry has a built-in SEO panel — meta title, description, and OG image. No schema changes needed. Access via <code>entry.seo.title</code>, <code>entry.seo.description</code>, and <code>entry.seo.ogImage</code>.' },
  { icon: '↑', title: 'FTP / FTPS deploy',            body: 'Upload your Astro <code>dist/</code> directly to any shared hosting via FTP or FTPS. Configure host, port, credentials, and remote path in Settings. One click to deploy — or trigger automatically after a build webhook.' },
  { icon: '⌗', title: 'Code snippets',               body: 'Built-in snippet library under Tools → Snippets. Copy-paste Astro code for contact forms, booking forms, SEO <code>&lt;head&gt;</code>, image rendering, getCollection, ticket buttons, RSS, and sitemap — dynamically adapted to your collection names.' },
  { icon: '⬛', title: 'Desktop App — Mac &amp; Windows',  body: 'Download the installer, double-click to launch. Pick a template (Blog, Portfolio, Business, Events) — the app creates collections and demo content automatically. No terminal, no Node.js, no npm.' },
  { icon: '⊕', title: 'WordPress importer',            body: 'Export your WordPress site as WXR and import it directly in the admin. HTML body text converts to Markdown automatically. Post dates, categories, and slugs are preserved. No CLI, no scripts.' },
  { icon: '⊘', title: 'Entry locking',                 body: 'When two editors open the same entry simultaneously, a lock warning appears before any changes are made. 90-second lock with automatic heartbeat refresh. Prevents silent last-write-wins overwrites.' },
  { icon: '⌨', title: 'CLI',                           body: '<code>orbiter init</code> scaffolds a new project with starter templates. <code>orbiter status</code> shows pod health. <code>orbiter sync</code> pushes/pulls via rsync. <code>orbiter encrypt/decrypt</code> wraps the pod in AES-256-GCM for git-safe storage.' },
  { icon: '◆', title: 'Publish HTML',                  body: 'One-click static site generator. Choose a built-in theme (Orbit or Canvas), click Generate, download a ZIP with a complete website. Dark mode, responsive, OG tags, sitemap — no Astro or build tools needed.' },
];

const tradeoffs = [
  { title: 'Not for large media libraries',  body: 'SQLite BLOB storage is convenient for content sites but not for thousands of high-res images. If your media library is in the gigabytes, this isn\'t the right tool.' },
  { title: 'Serverless requires extra steps', body: 'Netlify and Vercel don\'t persist filesystem writes between deploys. The GitHub sync mode works around this, but it adds steps. A VPS or Coolify gives you a better experience.' },
  { title: 'Built for small teams',          body: 'Two people editing the same entry at the same moment will get last-write-wins. Fine for a team of 1–5. Not designed for large editorial teams working in parallel.' },
];

const press = [
  {
    platform: 'devto',
    label: 'dev.to',
    title: 'I built a CMS that fits in one file — here\'s why and how',
    snippet: 'Every CMS I\'ve tried for Astro comes with the same overhead: a database to provision, a media CDN to configure...',
    href: 'https://dev.to/gerwin_weiher_7bf091b81c9/i-built-a-cms-that-fits-in-one-file-heres-why-and-how-h1f',
  },
  {
    platform: 'devto',
    label: 'dev.to',
    title: 'Building a standalone CMS admin with Hono and vanilla CSS glassmorphism',
    snippet: 'How I extracted the admin from the Astro integration into a standalone Hono server — architecture, CSS glassmorphism without a build step, and the theme system.',
    href: 'https://dev.to/gerwin_weiher_7bf091b81c9/building-a-standalone-cms-admin-with-hono-and-vanilla-css-glassmorphism-43l7',
  },
  {
    platform: 'hn',
    label: 'Hacker News',
    title: 'Show HN: Orbiter — CMS in one SQLite file for Astro',
    snippet: 'Hacker News discussion — community feedback, use cases, and technical questions.',
    href: 'https://news.ycombinator.com/item?id=47765327',
  },
  {
    platform: 'x',
    label: 'X · @gerwinweiher',
    title: 'Orbiter — CMS in one SQLite file for Astro',
    snippet: 'One file. No database server. No cloud account. Built for Astro. Copy it anywhere, back it up with cp.',
    href: 'https://x.com/gerwinweiher/status/2044049737188249823',
  },
];

// GitHub stars — fetched at build time (SSG, no client JS needed)
let ghStars = 0;
try {
  const ghRes = await fetch('https://api.github.com/repos/aeon022/orbiter', {
    headers: { 'Accept': 'application/vnd.github+json', 'X-GitHub-Api-Version': '2022-11-28' }
  });
  if (ghRes.ok) {
    const ghData = await ghRes.json();
    ghStars = ghData.stargazers_count ?? 0;
  }
} catch (_) {}

const faqs = [
  {
    q: 'What is a POD?',
    a: 'A POD is a standard SQLite database with a <code>.pod</code> extension. It contains all your content, media, users, and settings in one file. You can open it with any SQLite tool (TablePlus, DB Browser for SQLite, DBeaver) and inspect or query your content directly.',
  },
  {
    q: 'Do I need a database server?',
    a: 'No. SQLite runs in-process alongside your Astro server. Nothing to provision, nothing to pay for, nothing to configure separately. The database <em>is</em> the file.',
  },
  {
    q: 'Does it work on Netlify or Vercel?',
    a: 'Yes, with a note: serverless platforms don\'t persist filesystem writes between function invocations. Your content is available at build time for static generation, but for editing you need a persistent Node.js server (VPS, Railway, Coolify). Netlify/Vercel are great for hosting the frontend — run the Orbiter admin on a persistent server.',
  },
  {
    q: 'How do I back up my content?',
    a: '<code>cp content.pod backup.pod</code>. That\'s it. Every entry, every media file, every schema definition, every user account — in one file. Schedule a cron job, sync to S3, commit it to git. Standard file tooling works.',
  },
  {
    q: 'Can multiple people edit at the same time?',
    a: 'Orbiter supports multiple users with admin and editor roles. Two people editing the <em>same entry simultaneously</em> uses last-write-wins semantics. Fine for teams of 1–5 people, not designed for large editorial teams editing in parallel.',
  },
  {
    q: 'Is there a REST API?',
    a: '<code>GET /orbiter/api/[collection]</code> returns all published entries as JSON. Supports optional Bearer token authentication. Works from any frontend, mobile app, or external service without extra setup.',
  },
  {
    q: 'Can I import from WordPress?',
    a: 'Yes. Export your WordPress site as WXR (the standard WordPress XML export) and import it via the Orbiter admin. Text content, post dates, and categories are converted. HTML body text is transformed to Markdown automatically.',
  },
  {
    q: 'What Astro output mode do I need?',
    a: 'The Astro integration works with any output mode — it only provides <code>orbiter:collections</code> at build time. The admin runs as a separate server (<code>@a83/orbiter-admin</code>) independently of your Astro output mode.',
  },
  {
    q: 'Can I inspect the database directly?',
    a: 'Yes. Open <code>content.pod</code> with any SQLite GUI — TablePlus, DB Browser for SQLite, DBeaver, or the <code>sqlite3</code> CLI. Tables are <code>_collections</code>, <code>_entries</code>, <code>_media</code>, <code>_users</code>, <code>_sessions</code>, and <code>_versions</code>.',
  },
  {
    q: 'Is it production-ready?',
    a: 'Orbiter is at v0.3.78 — published to npm, actively maintained, and used in real projects. The API may evolve before v1.0. It\'s suitable for personal sites, client projects, and small teams. Check the GitHub issues for anything relevant to your use case.',
  },
  {
    q: 'What\'s the license?',
    a: 'MIT License. Use it for any project including commercial ones. Modify it, fork it, distribute it. No attribution required (though appreciated). The source is on GitHub and stays open source.',
  },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Orbiter — CMS in one file for Astro</title>
  <meta name="description" content="A CMS for Astro where your entire site — content, media, schema, users — lives in one portable SQLite file. Zero external dependencies. MIT License." />
  <link rel="canonical" href="https://orbiter.sh/" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content="Orbiter — CMS in one file" />
  <meta property="og:description" content="Content, media, schema, users — all in a single POD. One SQLite file. Copy it anywhere. Built for Astro." />
  <meta property="og:url"         content="https://orbiter.sh/" />
  <meta property="og:image"        content="https://orbiter.sh/og-card.png" />
  <meta property="og:image:alt"    content="Orbiter CMS — content, media, schema, users in one POD" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name"   content="Orbiter" />
  <meta property="og:locale"      content="en_US" />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="Orbiter — CMS in one file" />
  <meta name="twitter:description" content="Content, media, schema, users — all in a single POD. One SQLite file. Copy it anywhere. Built for Astro." />
  <meta name="twitter:image"       content="https://orbiter.sh/og-card.png" />
  <meta name="twitter:image:alt"   content="Orbiter CMS — content, media, schema, users in one POD" />
  <meta name="twitter:site"        content="@gerwinweiher" />

  <!-- Icons & PWA -->
  <link rel="icon"     href="/favicon.svg" type="image/svg+xml" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#8b7cf8" />

  <!-- Local font (no external request) -->
  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Orbiter",
    "url": "https://orbiter.sh",
    "description": "A CMS for Astro where your entire site — content, media, schema, users — lives in one portable SQLite file.",
    "publisher": { "@type": "Organization", "name": "Abteilung83", "url": "https://abteilung83.at" },
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://orbiter.sh/docs?q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Orbiter",
    "url": "https://orbiter.sh",
    "description": "A CMS for Astro where your entire site — content, media, schema, users — lives in one portable SQLite file.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "license": "https://opensource.org/licenses/MIT",
    "downloadUrl": "https://www.npmjs.com/package/@a83/orbiter-integration",
    "softwareVersion": "0.3.80",
    "author": { "@type": "Organization", "name": "Abteilung83", "url": "https://abteilung83.at" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a.replace(/<[^>]+>/g, '').replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&em;/g, 'em')
      }
    }))
  })} />
</head>
