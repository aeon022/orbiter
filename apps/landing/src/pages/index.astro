  <!-- SCREENSHOTS -->
  <section id="screenshots" class="screenshots-section">
    <h2 class="reveal">See it in action</h2>
    <p class="section-lead reveal reveal-delay-1">A full CMS admin — standalone server on port 4322, glassmorphism UI, three themes.</p>

    <div class="screenshot-main reveal reveal-delay-2">
      <div class="screenshot-frame" id="ss-main-frame">
        <img id="ss-main-img" src="/screenshots/xfce-dashboard.webp" alt="Orbiter Space Station mode — dark glassmorphism dashboard with floating dock" width="1440" height="900" />
      </div>
      <div class="screenshot-caption" id="ss-main-caption">Space Station mode — glass cards, stats sidebar, notes &amp; to-do, floating dock</div>
