---
import '../styles/landing.css';
import FooterSignature from '../components/FooterSignature.astro';
import CookieBanner from '../components/CookieBanner.astro';
import PageTransition from '../components/PageTransition.astro';

const features = [
  { icon: '◈', title: 'One file. Everything.',        body: 'Content, media, schema, users, sessions — all in a single <code>.pod</code> file. Copy it anywhere. Back it up with <code>cp</code>.' },
  { icon: '⬡', title: 'Astro-native',                 body: 'One line in <code>astro.config.mjs</code> injects a full admin UI at <code>/orbiter</code> via <code>injectRoute</code>. Nothing added to <code>src/pages</code>.' },
  { icon: '⌗', title: 'Familiar content API',         body: 'Read content with <code>getCollection</code> and <code>getEntry</code> — same shape as Astro\'s built-in content collections.' },
  { icon: '▦', title: 'Schema editor',                body: 'Add or change fields in the admin without writing migrations. Changes apply immediately.' },
  { icon: '◫', title: 'Media library',                body: 'Images and files stored as BLOBs directly in the pod. No CDN to configure, no broken paths after deploy.' },
  { icon: '⟳', title: 'Version history',              body: 'Every save creates a snapshot. Roll back to any previous version of any entry directly in the admin.' },
  { icon: '⊞', title: 'JSON API',                     body: '<code>GET /orbiter/api/[collection]</code> — optional Bearer token, ready to use from any frontend or mobile app.' },
  { icon: '⇅', title: 'Git sync mode',                 body: '<code>orbiter unpack</code> extracts media BLOBs to files, <code>orbiter pack</code> restores them. Commit your pod + media to Git — a GitHub Actions template is included for automatic rebuilds.' },
  { icon: '↓', title: 'Import',                       body: 'Migrate from WordPress (WXR export) or bring in Markdown files. Done in the admin, no CLI needed.' },
  { icon: '🌍', title: 'Multilingual',                body: 'Per-entry locale variants with <code>slug--locale</code> convention. <code>getLocaleCollection()</code> and locale fallback support built in.' },
  { icon: '⌘', title: 'Command palette',              body: '<code>⌘K</code> fuzzy search across all content and navigation. Installable as a PWA on mobile and desktop.' },
  { icon: '👥', title: 'Multi-user & roles',           body: 'Admin and editor roles. Manage users in the UI — no config file, no code change.' },
];

const tradeoffs = [
  { title: 'Not for large media libraries',  body: 'SQLite BLOB storage is convenient for content sites but not for thousands of high-res images. If your media library is in the gigabytes, this isn\'t the right tool.' },
  { title: 'Serverless requires extra steps', body: 'Netlify and Vercel don\'t persist filesystem writes between deploys. The GitHub sync mode works around this, but it adds steps. A VPS or Coolify gives you a better experience.' },
  { title: 'Built for small teams',          body: 'Two people editing the same entry at the same moment will get last-write-wins. Fine for a team of 1–5. Not designed for large editorial teams working in parallel.' },
];

const press = [
  {
    platform: 'reddit',
    label: 'Reddit · r/cms',
    title: 'Orbiter is now on npm — plus bulk actions, JSON API, and version history',
    snippet: 'Just shipped v0.1.0: multi-user auth, a full JSON API, version snapshots, and GitHub sync. Everything in one .pod file.',
    href: 'https://www.reddit.com/r/cms/comments/1sl6klg/orbiter_is_now_on_npm_plus_bulk_actions_json_api/',
  },
  {
    platform: 'devto',
    label: 'dev.to',
    title: 'I built a CMS that fits in one file — here\'s why and how',
    snippet: 'Every CMS I\'ve tried for Astro comes with the same overhead: a database to provision, a media CDN to configure...',
    href: 'https://dev.to/gerwin_weiher_7bf091b81c9/i-built-a-cms-that-fits-in-one-file-heres-why-and-how-h1f',
  },
  {
    platform: 'x',
    label: 'X · @gerwinweiher',
    title: 'Orbiter — CMS in one SQLite file for Astro',
    snippet: 'One file. No database server. No cloud account. Built for Astro. Copy it anywhere, back it up with cp.',
    href: 'https://x.com/gerwinweiher/status/2044049737188249823',
  },
  {
    platform: 'hn',
    label: 'Hacker News',
    title: 'Show HN: Orbiter — CMS in one SQLite file for Astro',
    snippet: 'Hacker News discussion — community feedback, use cases, and technical questions.',
    href: 'https://news.ycombinator.com/item?id=47765327',
  },
];

// GitHub stars — fetched at build time (SSG, no client JS needed)
let ghStars = 0;
try {
  const ghRes = await fetch('https://api.github.com/repos/aeon022/orbiter', {
    headers: { 'Accept': 'application/vnd.github+json', 'X-GitHub-Api-Version': '2022-11-28' }
  });
  if (ghRes.ok) {
    const ghData = await ghRes.json();
    ghStars = ghData.stargazers_count ?? 0;
  }
} catch (_) {}

const faqs = [
  {
    q: 'What is a .pod file?',
    a: 'A <code>.pod</code> file is a standard SQLite database — just with a custom extension. You can open it with any SQLite GUI (TablePlus, DB Browser for SQLite, DBeaver) and inspect or query your content directly. The extension makes it easy to identify in your project.',
  },
  {
    q: 'Do I need a database server?',
    a: 'No. SQLite runs in-process alongside your Astro server. Nothing to provision, nothing to pay for, nothing to configure separately. The database <em>is</em> the file.',
  },
  {
    q: 'Does it work on Netlify or Vercel?',
    a: 'Yes, with a note: serverless platforms don\'t persist filesystem writes between function invocations. Your content is available at build time for static generation, but for editing you need a persistent Node.js server (VPS, Railway, Coolify). Netlify/Vercel are great for hosting the frontend — run the Orbiter admin on a persistent server.',
  },
  {
    q: 'How do I back up my content?',
    a: '<code>cp content.pod backup.pod</code>. That\'s it. Every entry, every media file, every schema definition, every user account — in one file. Schedule a cron job, sync to S3, commit it to git. Standard file tooling works.',
  },
  {
    q: 'Can multiple people edit at the same time?',
    a: 'Orbiter supports multiple users with admin and editor roles. Two people editing the <em>same entry simultaneously</em> uses last-write-wins semantics. Fine for teams of 1–5 people, not designed for large editorial teams editing in parallel.',
  },
  {
    q: 'Is there a REST API?',
    a: '<code>GET /orbiter/api/[collection]</code> returns all published entries as JSON. Supports optional Bearer token authentication. Works from any frontend, mobile app, or external service without extra setup.',
  },
  {
    q: 'Can I import from WordPress?',
    a: 'Yes. Export your WordPress site as WXR (the standard WordPress XML export) and import it via the Orbiter admin. Text content, post dates, and categories are converted. HTML body text is transformed to Markdown automatically.',
  },
  {
    q: 'What Astro output mode do I need?',
    a: '<code>output: \'server\'</code> or <code>output: \'hybrid\'</code>. The admin UI needs a running server. Static-only (<code>output: \'static\'</code>) is not supported because there\'s nothing to serve the admin routes at runtime.',
  },
  {
    q: 'Can I inspect the database directly?',
    a: 'Yes. Open <code>content.pod</code> with any SQLite GUI — TablePlus, DB Browser for SQLite, DBeaver, or the <code>sqlite3</code> CLI. Tables are <code>_collections</code>, <code>_entries</code>, <code>_media</code>, <code>_users</code>, <code>_sessions</code>, and <code>_versions</code>.',
  },
  {
    q: 'Is it production-ready?',
    a: 'Orbiter is at v0.1.0 — published to npm, actively maintained, and used in real projects. The API may evolve before v1.0. It\'s suitable for personal sites, client projects, and small teams. Check the GitHub issues for anything relevant to your use case.',
  },
  {
    q: 'What\'s the license?',
    a: 'MIT License. Use it for any project including commercial ones. Modify it, fork it, distribute it. No attribution required (though appreciated). The source is on GitHub and stays open source.',
  },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Orbiter — CMS in one file for Astro</title>
  <meta name="description" content="A CMS for Astro where your entire site — content, media, schema, users — lives in one portable SQLite file. Zero external dependencies. MIT License." />
  <link rel="canonical" href="https://orbiter.sh/" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content="Orbiter — CMS in one file" />
  <meta property="og:description" content="Content, media, schema, users — all in a single .pod file. Copy it anywhere. Built for Astro." />
  <meta property="og:url"         content="https://orbiter.sh/" />
  <meta property="og:image"        content="https://orbiter.sh/og-card.png" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name"   content="Orbiter" />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="Orbiter — CMS in one file" />
  <meta name="twitter:description" content="Content, media, schema, users — all in a single .pod file. Copy it anywhere. Built for Astro." />
  <meta name="twitter:image"       content="https://orbiter.sh/og-card.png" />
  <meta name="twitter:site"        content="@gerwinweiher" />

  <!-- Icons & PWA -->
  <link rel="icon"     href="/favicon.svg" type="image/svg+xml" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#8b7cf8" />

  <!-- Local font (no external request) -->
  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Orbiter",
    "url": "https://orbiter.sh",
    "description": "A CMS for Astro where your entire site — content, media, schema, users — lives in one portable SQLite file.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "license": "https://opensource.org/licenses/MIT",
    "author": { "@type": "Organization", "name": "Abteilung83", "url": "https://abteilung83.at" }
  })} />
</head>
<body id="top">

  <!-- BACK TO TOP -->
  <button id="back-to-top" aria-label="Back to top" title="Back to top">↑</button>

  <!-- SCROLL PROGRESS -->
  <div id="scroll-progress" aria-hidden="true"></div>

  <!-- BACKGROUND -->
  <canvas id="starfield" aria-hidden="true"></canvas>
  <div class="nebula nebula-1" aria-hidden="true"></div>
  <div class="nebula nebula-2" aria-hidden="true"></div>
  <div class="nebula nebula-3" aria-hidden="true"></div>

  <!-- NAV -->
  <nav>
    <a href="#top" class="nav-logo"><span class="logo-icon" aria-hidden="true">🪐</span><span class="logo-text">Orbiter</span></a>
    <div class="nav-links">
      <a href="#how-it-works" data-section="how-it-works">How it works</a>
      <a href="#features"     data-section="features">Features</a>
      <a href="#pricing"      data-section="pricing">Pricing</a>
      <a href="#faq"          data-section="faq">FAQ</a>
      <a href="https://github.com/aeon022/orbiter" class="nav-cta" target="_blank" rel="noopener">
        ★ {ghStars > 0 ? ghStars : 'GitHub'}
      </a>
    </div>
    <button class="nav-hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- MOBILE MENU -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <a href="#how-it-works">How it works</a>
    <a href="#features">Features</a>
    <a href="#pricing">Pricing</a>
    <a href="#faq">FAQ</a>
    <a href="https://github.com/aeon022/orbiter" class="mobile-menu-cta" target="_blank" rel="noopener">★ GitHub {ghStars > 0 ? `(${ghStars})` : ''}</a>
  </div>

  <!-- HERO -->
  <div class="hero">
    <!-- orbital decoration -->
    <div class="orbit-wrap" aria-hidden="true">
      <div class="orbit orbit-1"></div>
      <div class="orbit orbit-2"></div>
      <div class="orbit orbit-3"></div>
    </div>

    <div class="hero-inner">
      <a href="https://github.com/aeon022/orbiter/releases" target="_blank" rel="noopener noreferrer" class="hero-badge">v0.1.0 — now on npm · Changelog →</a>
      <h1>Your entire CMS<br />in <span>one file.</span></h1>
      <p class="hero-sub">
        Content, media, schema, users — all in a single <code>.pod</code> file.
        Copy it anywhere. No database server. No cloud account.
        Built for Astro.
      </p>
      <div class="hero-actions">
        <a href="https://github.com/aeon022/orbiter" class="btn btn-primary">View on GitHub →</a>
        <a href="#how-it-works" class="btn btn-secondary">How it works</a>
        <a href="https://buy.polar.sh/polar_cl_SFvmYDegcsKDv8O8ZylLlIiXzyNRM7Br9nBx942rj4Q" target="_blank" rel="noopener noreferrer" class="btn btn-support">Support Orbiter ☕</a>
      </div>
      <div class="install-block">
        <span class="prompt">$</span>
        <span class="cmd">npm install @a83/orbiter-integration</span>
        <button class="copy-btn" data-copy="npm install @a83/orbiter-integration" aria-label="Copy install command" title="Copy to clipboard">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        </button>
      </div>

      <!-- Hero dashboard preview -->
      <div class="hero-preview">
        <div class="hero-preview-frame">
          <div class="hero-preview-bar">
            <div class="hero-preview-dot"></div>
            <div class="hero-preview-dot"></div>
            <div class="hero-preview-dot"></div>
            <div class="hero-preview-url">
              <span>localhost:4321/orbiter</span>
            </div>
          </div>
          <img src="/screenshots/dashboard.webp" alt="Orbiter admin dashboard" width="1390" height="839" />
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <div class="scroll-hint-line"></div>
    </div>
  </div>

  <!-- METRICS STRIP -->
  <div class="metrics-strip" aria-label="Key facts">
    <div class="metric">
      <span class="metric-value">0</span>
      <span class="metric-label">cloud deps</span>
    </div>
    <div class="metric">
      <span class="metric-value">MIT</span>
      <span class="metric-label">license</span>
    </div>
    <div class="metric">
      <span class="metric-value">1 file</span>
      <span class="metric-label">everything</span>
    </div>
    <div class="metric">
      <span class="metric-value">offline</span>
      <span class="metric-label">works without internet</span>
    </div>
    <div class="metric">
      <span class="metric-value">&lt; 5 min</span>
      <span class="metric-label">to first admin</span>
    </div>
  </div>

  <!-- PRESS / AS SEEN ON -->
  <section class="press-section">
    <div class="press-label reveal">As written about on</div>
    <div class="press-grid">
      {press.map((item, i) => (
        <a
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
          class={`press-card reveal reveal-delay-${i + 1}`}
        >
          <div class="press-platform">
            <div class={`press-icon ${item.platform}`}>
              {item.platform === 'reddit' && 'r/'}
              {item.platform === 'devto'  && 'D'}
              {item.platform === 'x'      && 'X'}
              {item.platform === 'hn'     && 'Y'}
            </div>
            {item.label}
          </div>
          <div class="press-title">{item.title}</div>
          <div class="press-snippet">{item.snippet}</div>
          <div class="press-arrow">Read article →</div>
        </a>
      ))}
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section id="screenshots" class="screenshots-section">
    <h2 class="reveal">See it in action</h2>
    <p class="section-lead reveal reveal-delay-1">A full CMS admin — injected into your Astro app. No separate service to run.</p>

    <div class="screenshot-main reveal reveal-delay-2">
      <div class="screenshot-frame" id="ss-main-frame">
        <img id="ss-main-img" src="/screenshots/dashboard.webp" alt="Orbiter Dashboard" width="1390" height="839" />
      </div>
      <div class="screenshot-caption" id="ss-main-caption">Dashboard — entry counts per collection, recently changed, live/draft status</div>
    </div>

    <div class="screenshot-grid">
      <button class="screenshot-thumb" data-src="/screenshots/dashboard.webp" data-caption="Dashboard — entry counts per collection, recently changed, live/draft status" aria-label="Dashboard">
        <div class="screenshot-frame"><img src="/screenshots/dashboard.webp" alt="" width="1390" height="839" loading="lazy" /></div>
        <div class="screenshot-caption">Dashboard</div>
      </button>
      <button class="screenshot-thumb" data-src="/screenshots/login.webp" data-caption="Login screen" aria-label="Login">
        <div class="screenshot-frame"><img src="/screenshots/login.webp" alt="" width="1390" height="839" loading="lazy" /></div>
        <div class="screenshot-caption">Login</div>
      </button>
      <button class="screenshot-thumb" data-src="/screenshots/settings.webp" data-caption="Settings — site config, GitHub sync mode, API token" aria-label="Settings &amp; GitHub sync">
        <div class="screenshot-frame"><img src="/screenshots/settings.webp" alt="" width="1390" height="839" loading="lazy" /></div>
        <div class="screenshot-caption">Settings &amp; GitHub sync</div>
      </button>
      <button class="screenshot-thumb" data-src="/screenshots/import.webp" data-caption="Import Tool — WordPress WXR and Markdown files" aria-label="Import Tool">
        <div class="screenshot-frame"><img src="/screenshots/import.webp" alt="" width="1390" height="839" loading="lazy" /></div>
        <div class="screenshot-caption">Import Tool</div>
      </button>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works">
    <h2 class="reveal">How it works</h2>
    <p class="section-lead reveal reveal-delay-1">Your entire CMS lives next to your source code — in one file.</p>

    <div class="file-visual reveal reveal-delay-2">
      <span class="dim">your-site/</span><br />
      <span class="dim">├── astro.config.mjs</span><br />
      <div class="file-highlight">
        ├── content.pod &nbsp;&nbsp;<span class="acc">← your entire CMS</span>
      </div>
      <span class="dim">└── src/pages/</span>
    </div>

    <div class="steps">
      <div class="reveal">
        <div class="step-label">Step 1 — Install</div>
        <div class="code-block">
          <pre><code>npm install @a83/orbiter-integration</code></pre>
          <button class="copy-btn code-copy-btn" aria-label="Copy code" title="Copy to clipboard"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
        </div>
      </div>
      <div class="reveal reveal-delay-1">
        <div class="step-label">Step 2 — Add to astro.config.mjs</div>
        <div class="code-block">
          <pre><code><span class="dim">import</span> orbiter <span class="dim">from</span> <span class="grn">'@a83/orbiter-integration'</span><span class="dim">;</span>

<span class="dim">export default</span> defineConfig(&#123;
  output: <span class="grn">'server'</span>,
  integrations: [orbiter(&#123; pod: <span class="grn">'./content.pod'</span> &#125;)],
&#125;);</code></pre>
          <button class="copy-btn code-copy-btn" aria-label="Copy code" title="Copy to clipboard"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
        </div>
      </div>
      <div class="reveal reveal-delay-2">
        <div class="step-label">Step 3 — Read content in your pages</div>
        <div class="code-block">
          <pre><code><span class="dim">import</span> &#123; getCollection &#125; <span class="dim">from</span> <span class="grn">'orbiter:collections'</span><span class="dim">;</span>

<span class="dim">const</span> posts = <span class="dim">await</span> getCollection(<span class="grn">'posts'</span>);</code></pre>
          <button class="copy-btn code-copy-btn" aria-label="Copy code" title="Copy to clipboard"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2 2v1"/></svg></button>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features">
    <h2 class="reveal">What's included</h2>
    <p class="section-lead reveal reveal-delay-1">A full CMS admin at <code>/orbiter</code> — injected into your Astro app, nothing added to <code>src/pages</code>.</p>

    <div class="grid reveal">
      {features.map(f => (
        <div class="feature">
          <span class="feature-icon">{f.icon}</span>
          <div class="feature-title">{f.title}</div>
          <div class="feature-body" set:html={f.body} />
        </div>
      ))}
    </div>
  </section>

  <!-- MANIFESTO: Your data. No strings attached. -->
  <section id="ownership" class="manifesto-section">
    <div class="manifesto-inner">

      <!-- Left: text + facts -->
      <div>
        <div class="manifesto-eyebrow reveal">No cloud. No lock-in. No compromise.</div>
        <h2 class="manifesto-headline reveal reveal-delay-1">Your data.<br />No strings attached.</h2>
        <p class="manifesto-body reveal reveal-delay-2">
          Every other CMS gives your content to a cloud. Orbiter gives it to you.
          A single <code>.pod</code> file — on your disk, in your repo, on your server.
          Copy it, encrypt it, email it. No account required. No monthly invoice.
          No vendor who can change pricing, shut down, or hold your data hostage.
        </p>
        <div class="manifesto-facts reveal reveal-delay-3">
          <div class="fact-item">
            <div class="fact-icon">📁</div>
            <div class="fact-text">
              <div class="fact-title">Backup in one command</div>
              <div class="fact-desc"><code>cp content.pod backup.pod</code> — that's your entire CMS. A 500-entry blog with images typically weighs under 50 MB.</div>
            </div>
          </div>
          <div class="fact-item">
            <div class="fact-icon">✈️</div>
            <div class="fact-text">
              <div class="fact-title">Works completely offline</div>
              <div class="fact-desc">Run <code>npm run dev</code> on your laptop with no internet. Edit content on a plane. No API calls, no auth endpoints, no CDN.</div>
            </div>
          </div>
          <div class="fact-item">
            <div class="fact-icon">🔍</div>
            <div class="fact-text">
              <div class="fact-title">Fully inspectable, always</div>
              <div class="fact-desc">Open your pod with any SQLite GUI. Run ad-hoc queries. No black box, no proprietary format, no data you can't read yourself.</div>
            </div>
          </div>
          <div class="fact-item">
            <div class="fact-icon">⚖️</div>
            <div class="fact-text">
              <div class="fact-title">MIT License — genuinely free</div>
              <div class="fact-desc">Use it commercially, fork it, sell products built with it. No "open core" bait-and-switch. The full source ships with your project.</div>
            </div>
          </div>
