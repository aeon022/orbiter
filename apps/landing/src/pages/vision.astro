<button class="btt" id="btt" aria-label="Back to top" title="Back to top">
  <div class="btt-pulse"></div>
  ↑
</button>

<script>
  // Reveal observer — handles all animated elements
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .rm-item').forEach(el => observer.observe(el));

  // Remove page curtain after animation
  const curtain = document.querySelector('.page-curtain');
  if (curtain) setTimeout(() => curtain.remove(), 2000);

  // Scroll parallax
  const planetScene = document.getElementById('planet-scene');
  const lightBeam = document.getElementById('light-beam');
  const lightBeamGlow = document.getElementById('light-beam-glow');
  const nav = document.querySelector('.vision-nav');
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        const vh = window.innerHeight;

        // Nav appears after hero
        if (nav) nav.classList.toggle('visible', scrollY > vh * 0.6);

        // Planet sinks and fades
        if (planetScene) {
          const progress = Math.min(scrollY / (vh * 1.2), 1);
          const translateY = progress * vh * 0.7;
          const opacity = 1 - progress * 1.4;
          const finalOpacity = Math.max(opacity, 0);
          planetScene.style.transform = `translateY(${translateY}px)`;
          planetScene.style.opacity = finalOpacity;
          planetScene.style.display = finalOpacity <= 0 ? 'none' : '';
        }

        // Vertical light beam grows from top
        if (lightBeam) {
          const beamStart = vh * 0.4;
          const beamScroll = Math.max(scrollY - beamStart, 0);
          const beamProgress = Math.min(beamScroll / (vh * 3), 1);
          const beamHeight = beamProgress * vh * 2.5;
          const beamOpacity = Math.min(beamProgress * 1.2, 0.5);
          lightBeam.style.height = beamHeight + 'px';
          lightBeam.style.opacity = beamOpacity;
          lightBeamGlow.style.height = beamHeight * 0.5 + 'px';
          lightBeamGlow.style.opacity = beamOpacity * 0.3;
        }

        // Roadmap scan glow + energy line
        const track = document.getElementById('roadmap-track');
        const glow = document.getElementById('roadmap-glow');
        const energy = document.getElementById('track-energy');
        if (track && glow) {
          const trackRect = track.getBoundingClientRect();
          const trackTop = trackRect.top;
          const trackH = trackRect.height;

          if (trackTop < vh && trackTop + trackH > 0) {
            glow.classList.add('active');
            const scanPos = Math.max(0, Math.min(vh * 0.45 - trackTop, trackH - 200));
            glow.style.top = scanPos + 'px';

            if (energy) {
              const energyH = Math.max(0, Math.min(scanPos + 100, trackH));
              energy.style.height = energyH + 'px';
            }
          } else {
            glow.classList.remove('active');
          }
        }

        ticking = false;
      });
      ticking = true;
    }
  });

  // ── Canvas Starfield ──
  const canvas = document.getElementById('starfield');
  const ctx = canvas.getContext('2d');
  let W = 0, H = 0, stars = [];

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  function initStars(n) {
    stars = Array.from({ length: n || 180 }, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      r: Math.random() * 1.3 + 0.2,
      vx: (Math.random() - 0.5) * 0.1,
      vy: (Math.random() - 0.5) * 0.1,
      base: Math.random() * 0.5 + 0.1,
      phase: Math.random() * Math.PI * 2,
      speed: Math.random() * 0.015 + 0.003,
    }));
  }
  function drawStars() {
    ctx.clearRect(0, 0, W, H);
    for (const s of stars) {
      s.phase += s.speed;
      const a = s.base + Math.sin(s.phase) * 0.2;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(210,215,255,' + a + ')';
      ctx.fill();
      s.x += s.vx;
      s.y += s.vy;
      if (s.x < -2) s.x = W + 2;
      if (s.x > W + 2) s.x = -2;
      if (s.y < -2) s.y = H + 2;
      if (s.y > H + 2) s.y = -2;
    }
    requestAnimationFrame(drawStars);
  }
  resize();
  initStars();
  drawStars();
  window.addEventListener('resize', () => { resize(); initStars(); });

  // Back to top button
  const btt = document.getElementById('btt');
  if (btt) {
    window.addEventListener('scroll', () => {
      btt.classList.toggle('visible', window.scrollY > window.innerHeight * 0.5);
    });
    btt.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

</body>
