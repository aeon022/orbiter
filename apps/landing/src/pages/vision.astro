---
import { ViewTransitions } from 'astro:transitions';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Vision — Orbiter</title>
  <meta name="description" content="Where Orbiter is going: Dual Render, AI-native content, agent-ready publishing. The future of CMS." />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="Orbiter Vision — Dual Render & the future of CMS" />
  <meta property="og:description" content="One DOM, two audiences. Content for humans and AI agents from a single source." />
  <meta property="og:url" content="https://orbiter.sh/vision" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Orbiter Vision — Dual Render & the future of CMS" />

  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
  <ViewTransitions />

  <style>
    @font-face {
      font-family: 'Inter';
      src: url('/fonts/inter-latin-wght-normal.woff2') format('woff2');
      font-weight: 100 900;
      font-display: swap;
    }

    :root {
      --bg: #08080f;
      --bg2: #0e0e1a;
      --text: #b8b8cc;
      --heading: #eeeef5;
      --accent: #8b7cf8;
      --accent2: #c4b9ff;
      --gold: #e6a817;
      --jade: #22c55e;
      --muted: #555570;
      --line: rgba(139,124,248,0.1);
      --glow: rgba(139,124,248,0.15);
    }

    * { margin:0; padding:0; box-sizing:border-box; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── Background — deep space ── */
    .vision-bg {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background: var(--bg);
    }

    /* ── Nav — compact, appears on scroll ── */
    .vision-nav {
      position: fixed; top: 16px; left: 50%; transform: translateX(-50%) translateY(-80px);
      width: auto; z-index: 200;
      display: flex; align-items: center; gap: 6px;
      padding: 8px 10px 8px 16px;
      background: rgba(7,7,15,0.7);
      backdrop-filter: blur(22px); -webkit-backdrop-filter: blur(22px);
      border: 1px solid rgba(139,124,248,0.15);
      border-radius: 28px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.4);
      opacity: 0;
      transition: transform 0.4s ease, opacity 0.4s ease;
    }
    .vision-nav.visible {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
    .vision-nav a { color: var(--muted); text-decoration: none; font-size: 11px; transition: color 0.15s; padding: 4px 10px; letter-spacing: 0.03em; }
    .vision-nav a:hover { color: var(--heading); }
    .vision-nav-logo { display: flex; align-items: center; gap: 6px; font-weight: 700; color: var(--heading); font-size: 11px; letter-spacing: 0.13em; text-transform: uppercase; padding: 0 8px 0 0; border-right: 1px solid var(--line); margin-right: 2px; }
    .vision-nav-logo svg { width: 18px; height: 18px; }
    .vision-nav-links { display: flex; gap: 2px; align-items: center; }
    .vision-nav-links .btn-sm { padding: 5px 14px; border: 1px solid rgba(139,124,248,0.3); color: var(--accent); border-radius: 16px; font-size: 10px; letter-spacing: 0.04em; transition: all 0.15s; }
    .vision-nav-links .btn-sm:hover { background: var(--accent); color: var(--bg); border-color: var(--accent); }

    /* ── Page load sequence ── */
    .page-curtain {
      position: fixed; inset: 0; z-index: 300;
      background: #000;
      pointer-events: none;
      animation: curtain-lift 1.2s ease 0.3s forwards;
    }
    @keyframes curtain-lift {
      0% { opacity: 1; }
      100% { opacity: 0; }
    }
    .planet-scene { animation: planet-rise 2s ease-out 0.5s both; }
    @keyframes planet-rise {
      from { transform: translateY(100px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    /* ── Planet horizon — view from station, scrolls away ── */
    .planet-scene {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      transition: none;
      will-change: transform, opacity;
    }
    .planet-wrap {
      position: absolute; bottom: -110vh; left: 50%; transform: translateX(-50%);
      width: 250vw; height: 160vh;
    }
    .planet-body {
      position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
      width: 250vw; height: 160vh;
      border-radius: 50%;
      background: radial-gradient(ellipse at 50% 8%, #151030 0%, #0c0a1a 30%, #060510 100%);
    }
    .planet-atmo {
      position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
      width: 250vw; height: 160vh;
      border-radius: 50%;
      box-shadow:
        0 -5px 150px 25px rgba(139,124,248,0.35),
        0 -3px 300px 80px rgba(139,124,248,0.15),
        0 0 500px 150px rgba(100,80,220,0.07);
    }
    .planet-glow {
      position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
      width: 250vw; height: 160vh;
      border-radius: 50%;
      box-shadow:
        0 -1px 80px 15px rgba(196,185,255,0.5),
        0 -1px 30px 5px rgba(196,185,255,0.7),
        0 -1px 8px 2px rgba(230,225,255,0.8);
      animation: atmo-pulse 5s ease-in-out infinite;
    }
    .planet-glow-2 {
      position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
      width: 250vw; height: 160vh;
      border-radius: 50%;
      box-shadow:
        0 -2px 120px 30px rgba(139,124,248,0.2),
        0 -1px 60px 15px rgba(196,185,255,0.15);
      animation: atmo-pulse 3s ease-in-out infinite 1s;
    }
    .planet-glow-warm {
      position: absolute; bottom: 0; left: 40%; transform: translateX(-50%);
      width: 250vw; height: 160vh;
      border-radius: 50%;
      box-shadow:
        0 -2px 120px 20px rgba(230,168,23,0.1),
        0 -1px 60px 8px rgba(230,168,23,0.07);
      animation: atmo-pulse 7s ease-in-out infinite reverse;
    }
    .planet-horizon-line {
      position: absolute; bottom: calc(110vh + 10px); left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg,
        transparent 2%,
        rgba(100,80,220,0.15) 12%,
        rgba(139,124,248,0.4) 30%,
        rgba(196,185,255,0.7) 45%,
        rgba(230,225,255,0.9) 50%,
        rgba(196,185,255,0.7) 55%,
        rgba(139,124,248,0.4) 70%,
        rgba(100,80,220,0.15) 88%,
        transparent 98%
      );
    }
    .planet-flare {
      position: absolute; bottom: calc(110vh + 10px); left: 50%; transform: translateX(-50%);
      width: 700px; height: 160px;
      background: radial-gradient(ellipse, rgba(196,185,255,0.25) 0%, rgba(139,124,248,0.1) 35%, transparent 70%);
      animation: flare-breathe 4s ease-in-out infinite;
    }
    .planet-flare-wide {
      position: absolute; bottom: calc(110vh + 20px); left: 50%; transform: translateX(-50%);
      width: 100vw; height: 60px;
      background: linear-gradient(0deg, rgba(139,124,248,0.1), transparent);
    }
    .planet-shimmer {
      position: absolute; bottom: calc(110vh + 8px); left: 0; right: 0; height: 8px;
      background: linear-gradient(90deg,
        transparent, rgba(196,185,255,0.0) 15%,
        rgba(196,185,255,0.2), rgba(220,210,255,0.5), rgba(230,225,255,0.6),
        rgba(220,210,255,0.5), rgba(196,185,255,0.2),
        rgba(196,185,255,0.0) 85%, transparent
      );
      background-size: 300% 100%;
      animation: shimmer-slide 6s linear infinite;
    }
    .planet-shimmer-2 {
      position: absolute; bottom: calc(110vh + 12px); left: 0; right: 0; height: 4px;
      background: linear-gradient(90deg,
        transparent 10%, rgba(230,168,23,0.1) 30%, rgba(230,168,23,0.2) 50%,
        rgba(230,168,23,0.1) 70%, transparent 90%
      );
      background-size: 250% 100%;
      animation: shimmer-slide 10s linear infinite reverse;
    }


    /* Vertical light beam — grows on scroll */
    .light-beam {
      position: fixed; top: 0; left: 50%; transform: translateX(-50%);
      width: 1px; height: 0;
      background: linear-gradient(180deg, rgba(196,185,255,0.5), rgba(139,124,248,0.2), transparent);
      z-index: 0; pointer-events: none;
      will-change: height, opacity;
      box-shadow: 0 0 15px 3px rgba(139,124,248,0.08), 0 0 40px 8px rgba(139,124,248,0.04);
    }
    .light-beam-glow {
      position: fixed; top: 0; left: 50%; transform: translateX(-50%);
      width: 120px; height: 0;
      background: radial-gradient(ellipse at 50% 0%, rgba(139,124,248,0.06) 0%, transparent 70%);
      z-index: 0; pointer-events: none;
      will-change: height, opacity;
    }

    /* Canvas starfield */
    #starfield {
      position: fixed; inset: 0; z-index: 0;
      pointer-events: none;
    }

    /* Nebulas — drifting color blobs */
    .nebula {
      position: fixed; border-radius: 50%;
      pointer-events: none; z-index: 0;
    }
    .nebula-1 {
      width: 800px; height: 800px; top: -300px; left: -300px;
      background: radial-gradient(circle, rgba(108,92,231,0.12) 0%, transparent 65%);
      filter: blur(60px);
      animation: neb-drift-1 25s ease-in-out infinite alternate;
    }
    .nebula-2 {
      width: 600px; height: 600px; bottom: 10%; right: -250px;
      background: radial-gradient(circle, rgba(230,168,23,0.06) 0%, transparent 65%);
      filter: blur(60px);
      animation: neb-drift-2 30s ease-in-out infinite alternate;
    }
    .nebula-3 {
      width: 500px; height: 500px; top: 45%; left: 35%;
      background: radial-gradient(circle, rgba(139,124,248,0.06) 0%, transparent 65%);
      filter: blur(80px);
      animation: neb-drift-3 20s ease-in-out infinite alternate;
    }
    @keyframes neb-drift-1 { from { transform: translate(0,0) scale(1); } to { transform: translate(50px,30px) scale(1.12); } }
    @keyframes neb-drift-2 { from { transform: translate(0,0) scale(1); } to { transform: translate(-40px,-20px) scale(1.08); } }
    @keyframes neb-drift-3 { from { transform: translate(0,0) scale(1); } to { transform: translate(30px,-25px) scale(1.1); } }

    @keyframes atmo-pulse {
      0%, 100% { opacity: 0.7; }
      50% { opacity: 1; }
    }
    @keyframes flare-breathe {
      0%, 100% { opacity: 0.6; transform: translateX(-50%) scaleX(1); }
      50% { opacity: 1; transform: translateX(-50%) scaleX(1.15); }
    }
    @keyframes shimmer-slide {
      from { background-position: 200% 0; }
      to { background-position: -200% 0; }
    }

    /* ── Sections ── */
    .vision-section {
      position: relative; z-index: 1;
      max-width: 900px; margin: 0 auto;
      padding: 0 32px;
    }

    /* ── Hero ── */
    .vision-hero {
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding-top: 80px;
      position: relative; overflow: hidden;
    }
    .vision-eyebrow {
      font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 24px;
      opacity: 0; animation: fadeUp 0.8s 1.2s forwards;
      position: relative; z-index: 2;
    }
    .vision-h1 {
      font-size: clamp(36px, 6vw, 64px);
      font-weight: 300; color: var(--heading);
      line-height: 1.15; margin-bottom: 24px;
      opacity: 0; animation: fadeUp 1s 1.5s forwards;
      position: relative; z-index: 2;
    }
    .vision-h1 em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent), var(--gold));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .vision-sub {
      font-size: 18px; color: var(--text); max-width: 600px;
      margin-bottom: 48px;
      opacity: 0; animation: fadeUp 0.8s 2s forwards;
      position: relative; z-index: 2;
    }
    .vision-scroll-hint {
      font-size: 11px; color: var(--muted); letter-spacing: 0.15em;
      opacity: 0; animation: fadeUp 0.8s 2.6s forwards;
      position: relative; z-index: 2;
    }
    .vision-scroll-hint span {
      display: inline-block; animation: bounce 2s infinite;
    }

    /* ── Dual Render Block ── */
    .dual-section { padding: 120px 32px; max-width: 1000px; margin: 0 auto; position: relative; z-index: 1; }

    .dual-label {
      font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 12px;
    }
    .dual-h2 {
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 300; color: var(--heading);
      line-height: 1.2; margin-bottom: 20px;
    }
    .dual-body { font-size: 16px; color: var(--text); max-width: 640px; margin-bottom: 48px; }

    /* Diagram */
    .dual-diagram {
      display: grid; grid-template-columns: 1fr auto 1fr; gap: 0; align-items: stretch;
      border: 1px solid var(--line); border-radius: 16px;
      overflow: hidden; margin-bottom: 64px;
      background: rgba(14,14,26,0.6);
      backdrop-filter: blur(12px);
    }
    .dual-col {
      padding: 32px 28px;
    }
    .dual-col-center {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 32px 20px; border-left: 1px solid var(--line); border-right: 1px solid var(--line);
      background: rgba(139,124,248,0.04);
    }
    .dual-col-label {
      font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 16px;
    }
    .dual-col-icon { font-size: 28px; margin-bottom: 12px; opacity: 0.7; }
    .dual-col-title { font-size: 15px; font-weight: 600; color: var(--heading); margin-bottom: 8px; }
    .dual-col-items { list-style: none; font-size: 13px; color: var(--text); }
    .dual-col-items li { padding: 4px 0; display: flex; align-items: center; gap: 8px; }
    .dual-col-items li::before { content: '→'; color: var(--accent); font-size: 11px; flex-shrink: 0; }
    .dual-col-center .dual-col-items li::before { content: '◈'; }
    .dual-arrow { color: var(--accent); font-size: 20px; margin: 8px 0; }

    /* Flow */
    .dual-flow {
      display: flex; align-items: center; justify-content: center; gap: 16px;
      margin-bottom: 64px; flex-wrap: wrap;
    }
    .flow-node {
      padding: 10px 20px; border: 1px solid var(--line); border-radius: 8px;
      font-size: 13px; color: var(--heading); background: var(--bg2);
      text-align: center; min-width: 120px;
    }
    .flow-node.accent { border-color: var(--accent); background: rgba(139,124,248,0.08); }
    .flow-node.gold { border-color: var(--gold); background: rgba(230,168,23,0.06); color: var(--gold); }
    .flow-arrow { color: var(--muted); font-size: 18px; }

    /* ── Roadmap ── */
    .roadmap-section { padding: 120px 32px; max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }

    .roadmap-track { position: relative; padding-left: 40px; }
    .roadmap-track::before {
      content: ''; position: absolute; left: 12px; top: 0; bottom: 0;
      width: 1px; background: linear-gradient(to bottom, var(--accent), var(--gold), var(--muted));
    }

    /* Sci-fi scan light that follows scroll through the timeline */
    .roadmap-glow {
      position: absolute; left: -60px; width: calc(100% + 120px);
      height: 200px; pointer-events: none;
      background: radial-gradient(ellipse at 50% 50%,
        rgba(139,124,248,0.12) 0%,
        rgba(139,124,248,0.05) 30%,
        transparent 70%
      );
      opacity: 0;
      transition: opacity 0.3s ease;
      will-change: top;
    }
    .roadmap-glow.active { opacity: 1; }
    .roadmap-glow::before {
      content: ''; position: absolute; left: 60px; top: 50%;
      width: 3px; height: 60px; transform: translateY(-50%);
      background: linear-gradient(180deg, transparent, var(--accent), transparent);
      border-radius: 2px;
      box-shadow: 0 0 20px 4px rgba(139,124,248,0.3), 0 0 60px 10px rgba(139,124,248,0.1);
    }
    .roadmap-glow::after {
      content: ''; position: absolute; left: 0; right: 0; top: 50%; height: 1px;
      background: linear-gradient(90deg,
        transparent 5%,
        rgba(139,124,248,0.08) 20%,
        rgba(139,124,248,0.15) 50%,
        rgba(139,124,248,0.08) 80%,
        transparent 95%
      );
    }

    /* Energized timeline line — glows when items are visible */
    .roadmap-track-energy {
      position: absolute; left: 11px; top: 0; width: 3px; height: 0;
      background: linear-gradient(180deg, var(--jade), var(--accent));
      border-radius: 2px;
      box-shadow: 0 0 8px rgba(139,124,248,0.3), 0 0 20px rgba(139,124,248,0.1);
      transition: height 0.6s cubic-bezier(0.16,1,0.3,1);
    }

    .rm-item { position: relative; margin-bottom: 48px; }
    .rm-dot {
      position: absolute; left: -40px; top: 4px;
      width: 24px; height: 24px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; border: 2px solid var(--line);
      background: var(--bg);
    }
    .rm-dot.done { border-color: var(--jade); color: var(--jade); }
    .rm-dot.next { border-color: var(--accent); color: var(--accent); background: rgba(139,124,248,0.1); box-shadow: 0 0 12px var(--glow); }
    .rm-dot.future { border-color: var(--muted); color: var(--muted); }
    .rm-phase {
      font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 4px;
    }
    .rm-title { font-size: 18px; font-weight: 500; color: var(--heading); margin-bottom: 6px; }
    .rm-desc { font-size: 13px; color: var(--text); line-height: 1.6; }
    .rm-tag {
      display: inline-block; font-size: 9px; padding: 2px 8px; margin-top: 8px;
      border-radius: 3px; letter-spacing: 0.06em;
    }
    .rm-tag.done { color: var(--jade); background: rgba(34,197,94,0.1); }
    .rm-tag.next { color: var(--accent); background: rgba(139,124,248,0.1); }
    .rm-tag.future { color: var(--muted); background: rgba(85,85,112,0.15); }

    /* ── Back to top ── */
    .btt {
      position: fixed; bottom: 28px; right: 28px; z-index: 150;
      width: 44px; height: 44px;
      border-radius: 50%;
      background: rgba(7,7,15,0.7);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(139,124,248,0.2);
      color: var(--accent);
      font-size: 18px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      opacity: 0; transform: translateY(20px);
      transition: opacity 0.3s, transform 0.3s, box-shadow 0.3s, border-color 0.3s;
      pointer-events: none;
      overflow: hidden;
    }
    .btt.visible { opacity: 1; transform: translateY(0); pointer-events: all; }
    .btt:hover {
      border-color: var(--accent);
      box-shadow: 0 0 20px rgba(139,124,248,0.3), 0 0 40px rgba(139,124,248,0.1);
    }
    .btt::before {
      content: '';
      position: absolute; inset: 0; border-radius: 50%;
      padding: 1px;
      background: conic-gradient(from var(--btt-angle, 0deg), transparent 60%, rgba(139,124,248,0.5) 70%, transparent 80%);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      animation: btt-spin 4s linear infinite;
    }
    @property --btt-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
    @keyframes btt-spin { to { --btt-angle: 360deg; } }
    .btt-pulse {
      position: absolute; inset: -4px; border-radius: 50%;
      border: 1px solid rgba(139,124,248,0.15);
      animation: btt-pulse-anim 2s ease-in-out infinite;
    }
    @keyframes btt-pulse-anim {
      0%, 100% { transform: scale(1); opacity: 0.5; }
      50% { transform: scale(1.15); opacity: 0; }
    }

    /* ── CTA ── */
    .vision-cta {
      text-align: center; padding: 120px 32px 80px;
      position: relative; z-index: 1;
    }
    .vision-cta h2 { font-size: 32px; font-weight: 300; color: var(--heading); margin-bottom: 16px; }
    .vision-cta p { color: var(--text); margin-bottom: 32px; }
    .vision-cta-links { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .vision-cta-links a {
      padding: 12px 28px; border-radius: 24px; font-size: 14px;
      text-decoration: none; transition: all 0.15s;
    }
    .btn-primary { background: var(--accent); color: #fff; border: 1px solid var(--accent); }
    .btn-primary:hover { background: var(--accent2); border-color: var(--accent2); color: var(--bg); }
    .btn-ghost { background: transparent; color: var(--text); border: 1px solid var(--line); }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Warp Footer ── */
    .warp-footer {
      position: relative; z-index: 1;
      overflow: hidden;
      margin-top: 40px;
    }
    .warp-scene {
      position: relative; min-height: 480px;
      display: flex; flex-direction: column;
      align-items: center; justify-content: flex-end;
      padding-bottom: 40px;
    }
    .warp-nebula {
      position: absolute; bottom: -70%; left: 50%; transform: translateX(-50%);
      width: 200vw; height: 100%;
      border-radius: 50%;
      background: radial-gradient(ellipse at 50% 85%, #18122e 0%, #0c0a1a 50%, transparent 100%);
    }
    .warp-corona {
      position: absolute; bottom: -70%; left: 50%; transform: translateX(-50%);
      width: 200vw; height: 100%;
      border-radius: 50%;
      box-shadow:
        0 -3px 120px 20px rgba(230,168,23,0.18),
        0 -2px 60px 8px rgba(255,200,80,0.25),
        0 -1px 20px 3px rgba(255,210,100,0.35);
      animation: warp-pulse 6s ease-in-out infinite;
    }
    .warp-corona-accent {
      position: absolute; bottom: -70%; left: 50%; transform: translateX(-50%);
      width: 200vw; height: 100%;
      border-radius: 50%;
      box-shadow:
        0 -2px 100px 15px rgba(139,124,248,0.1),
        0 -1px 40px 6px rgba(139,124,248,0.06);
      animation: warp-pulse 4s ease-in-out infinite 1.5s;
    }
    .warp-line {
      position: absolute; bottom: 50%; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg,
        transparent 5%,
        rgba(230,168,23,0.08) 20%,
        rgba(230,168,23,0.25) 40%,
        rgba(255,200,80,0.5) 50%,
        rgba(230,168,23,0.25) 60%,
        rgba(230,168,23,0.08) 80%,
        transparent 95%
      );
    }
    .warp-shimmer {
      position: absolute; bottom: calc(50% - 3px); left: 0; right: 0; height: 6px;
      background: linear-gradient(90deg,
        transparent, rgba(255,200,80,0.0) 20%,
        rgba(255,200,80,0.12), rgba(255,220,120,0.25),
        rgba(255,200,80,0.12), rgba(255,200,80,0.0) 80%, transparent
      );
      background-size: 300% 100%;
      animation: shimmer-slide 7s linear infinite;
    }
    .warp-flare {
      position: absolute; bottom: calc(50% - 50px); left: 50%; transform: translateX(-50%);
      width: 400px; height: 100px;
      background: radial-gradient(ellipse, rgba(255,200,80,0.1) 0%, transparent 70%);
      animation: warp-pulse 5s ease-in-out infinite 0.5s;
    }

    .warp-content {
      position: relative; z-index: 2;
      text-align: center; padding: 0 32px;
    }
    .warp-quote {
      font-size: 15px; font-style: italic; color: var(--muted);
      max-width: 460px; margin: 0 auto 8px;
      line-height: 1.7;
    }
    .warp-quote em { font-style: normal; color: var(--heading); }
    .warp-attr {
      font-size: 10px; color: var(--muted); letter-spacing: 0.1em;
      margin-bottom: 32px;
    }
    .warp-links {
      display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;
      margin-bottom: 24px;
    }
    .warp-links a {
      color: var(--muted); text-decoration: none; font-size: 11px;
      letter-spacing: 0.06em; transition: color 0.15s;
    }
    .warp-links a:hover { color: var(--accent); }
    .warp-copy {
      font-size: 10px; color: rgba(85,85,112,0.5);
    }
    .warp-copy a { color: rgba(139,124,248,0.4); text-decoration: none; }
    .warp-copy a:hover { color: var(--accent); }

    @keyframes warp-pulse {
      0%, 100% { opacity: 0.6; }
      50% { opacity: 1; }
    }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(5px); }
    }

    .reveal {
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-d1 { transition-delay: 0.12s; }
    .reveal-d2 { transition-delay: 0.24s; }
    .reveal-d3 { transition-delay: 0.36s; }
    .reveal-d4 { transition-delay: 0.48s; }

    /* Slide from left/right */
    .reveal-left { opacity: 0; transform: translateX(-40px); transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1); }
    .reveal-right { opacity: 0; transform: translateX(40px); transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1); }
    .reveal-left.visible, .reveal-right.visible { opacity: 1; transform: translateX(0); }

    /* Scale in */
    .reveal-scale { opacity: 0; transform: scale(0.92); transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.16,1,0.3,1); }
    .reveal-scale.visible { opacity: 1; transform: scale(1); }

    /* Roadmap dot glow-up on scroll */
    .rm-dot { transition: box-shadow 0.5s ease, border-color 0.5s ease, transform 0.3s ease; }
    .rm-item.visible .rm-dot.done { box-shadow: 0 0 12px rgba(34,197,94,0.3); transform: scale(1.1); }
    .rm-item.visible .rm-dot.next { box-shadow: 0 0 16px var(--glow); transform: scale(1.15); }
    .rm-item.visible .rm-dot.future { box-shadow: 0 0 8px rgba(85,85,112,0.2); }

    /* ── Responsive ── */
    @media (max-width: 700px) {
      .dual-diagram { grid-template-columns: 1fr; }
      .dual-col-center { border-left: none; border-right: none; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
      .dual-flow { flex-direction: column; }
      .flow-arrow { transform: rotate(90deg); }
      .vision-nav { width: calc(100vw - 32px); padding: 10px 14px 10px 16px; top: 12px; border-radius: 20px; justify-content: space-between; }
      .vision-nav-logo { font-size: 10px; gap: 5px; }
      .vision-nav-logo svg { width: 16px; height: 16px; }
      .vision-nav-links { gap: 2px; }
      .vision-nav a { font-size: 10px; padding: 4px 8px; }
      .vision-h1 { font-size: 28px; }
      .vision-sub { font-size: 14px; max-width: 90vw; }
      .dual-section, .roadmap-section { padding: 60px 16px; }
      .planet-wrap { bottom: -200px; width: 300vw; height: 400px; }
      .planet-body, .planet-atmo, .planet-glow, .planet-glow-2, .planet-glow-warm { width: 300vw; height: 400px; }
      .planet-horizon-line { bottom: 210px; }
      .planet-shimmer { bottom: 208px; }
      .planet-shimmer-2 { bottom: 212px; }
      .planet-flare { bottom: 210px; width: 250px; }
      .planet-flare-wide { bottom: 220px; }
      .warp-scene { min-height: 360px; }
    }

    /* Extra small — portrait phones */
    @media (max-width: 420px) {
      .vision-h1 { font-size: 24px; }
      .planet-wrap { bottom: -150px; height: 300px; }
      .planet-body, .planet-atmo, .planet-glow, .planet-glow-2, .planet-glow-warm { height: 300px; }
      .planet-horizon-line { bottom: 160px; }
      .planet-shimmer { bottom: 158px; }
      .planet-shimmer-2 { bottom: 162px; }
      .planet-flare { bottom: 160px; width: 200px; }
      .planet-flare-wide { bottom: 170px; }
      .vision-nav-links .btn-sm { display: none; }
    }
  </style>
</head>
