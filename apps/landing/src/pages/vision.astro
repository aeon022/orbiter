---
import { ViewTransitions } from 'astro:transitions';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Vision — Orbiter</title>
  <meta name="description" content="Where Orbiter is going: Dual Render, AI-native content, agent-ready publishing. The future of CMS." />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="Orbiter Vision — Dual Render & the future of CMS" />
  <meta property="og:description" content="One DOM, two audiences. Content for humans and AI agents from a single source." />
  <meta property="og:url" content="https://orbiter.sh/vision" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Orbiter Vision — Dual Render & the future of CMS" />

  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
  <ViewTransitions />

  <style>
    @font-face {
      font-family: 'Inter';
      src: url('/fonts/inter-latin-wght-normal.woff2') format('woff2');
      font-weight: 100 900;
      font-display: swap;
    }

    :root {
      --bg: #08080f;
      --bg2: #0e0e1a;
      --text: #b8b8cc;
      --heading: #eeeef5;
      --accent: #8b7cf8;
      --accent2: #c4b9ff;
      --gold: #e6a817;
      --jade: #22c55e;
      --muted: #555570;
      --line: rgba(139,124,248,0.1);
      --glow: rgba(139,124,248,0.15);
    }

    * { margin:0; padding:0; box-sizing:border-box; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── Background ── */
    .vision-bg {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse at 20% 0%, rgba(139,124,248,0.08) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 100%, rgba(230,168,23,0.05) 0%, transparent 50%),
        var(--bg);
    }
    .grid-overlay {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image:
        linear-gradient(rgba(139,124,248,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(139,124,248,0.03) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse at 50% 30%, black 20%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse at 50% 30%, black 20%, transparent 70%);
    }

    /* ── Nav ── */
    .vision-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 40px;
      background: rgba(8,8,15,0.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--line);
    }
    .vision-nav a { color: var(--text); text-decoration: none; font-size: 13px; transition: color 0.15s; }
    .vision-nav a:hover { color: var(--accent); }
    .vision-nav-logo { display: flex; align-items: center; gap: 8px; font-weight: 600; color: var(--heading); font-size: 15px; }
    .vision-nav-links { display: flex; gap: 24px; align-items: center; }
    .vision-nav-links .btn-sm { padding: 6px 16px; border: 1px solid var(--accent); color: var(--accent); border-radius: 20px; font-size: 12px; letter-spacing: 0.04em; transition: all 0.15s; }
    .vision-nav-links .btn-sm:hover { background: var(--accent); color: var(--bg); }

    /* ── Sections ── */
    .vision-section {
      position: relative; z-index: 1;
      max-width: 900px; margin: 0 auto;
      padding: 0 32px;
    }

    /* ── Hero ── */
    .vision-hero {
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding-top: 80px;
    }
    .vision-eyebrow {
      font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 24px;
      opacity: 0; animation: fadeUp 0.8s 0.2s forwards;
    }
    .vision-h1 {
      font-size: clamp(36px, 6vw, 64px);
      font-weight: 300; color: var(--heading);
      line-height: 1.15; margin-bottom: 24px;
      opacity: 0; animation: fadeUp 0.8s 0.4s forwards;
    }
    .vision-h1 em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent), var(--gold));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .vision-sub {
      font-size: 18px; color: var(--text); max-width: 600px;
      margin-bottom: 48px;
      opacity: 0; animation: fadeUp 0.8s 0.6s forwards;
    }
    .vision-scroll-hint {
      font-size: 11px; color: var(--muted); letter-spacing: 0.15em;
      opacity: 0; animation: fadeUp 0.8s 1s forwards;
    }
    .vision-scroll-hint span {
      display: inline-block; animation: bounce 2s infinite;
    }

    /* ── Dual Render Block ── */
    .dual-section { padding: 120px 32px; max-width: 1000px; margin: 0 auto; position: relative; z-index: 1; }

    .dual-label {
      font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 12px;
    }
    .dual-h2 {
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 300; color: var(--heading);
      line-height: 1.2; margin-bottom: 20px;
    }
    .dual-body { font-size: 16px; color: var(--text); max-width: 640px; margin-bottom: 48px; }

    /* Diagram */
    .dual-diagram {
      display: grid; grid-template-columns: 1fr auto 1fr; gap: 0; align-items: stretch;
      border: 1px solid var(--line); border-radius: 16px;
      overflow: hidden; margin-bottom: 64px;
      background: rgba(14,14,26,0.6);
      backdrop-filter: blur(12px);
    }
    .dual-col {
      padding: 32px 28px;
    }
    .dual-col-center {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 32px 20px; border-left: 1px solid var(--line); border-right: 1px solid var(--line);
      background: rgba(139,124,248,0.04);
    }
    .dual-col-label {
      font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 16px;
    }
    .dual-col-icon { font-size: 28px; margin-bottom: 12px; opacity: 0.7; }
    .dual-col-title { font-size: 15px; font-weight: 600; color: var(--heading); margin-bottom: 8px; }
    .dual-col-items { list-style: none; font-size: 13px; color: var(--text); }
    .dual-col-items li { padding: 4px 0; display: flex; align-items: center; gap: 8px; }
    .dual-col-items li::before { content: '→'; color: var(--accent); font-size: 11px; flex-shrink: 0; }
    .dual-col-center .dual-col-items li::before { content: '◈'; }
    .dual-arrow { color: var(--accent); font-size: 20px; margin: 8px 0; }

    /* Flow */
    .dual-flow {
      display: flex; align-items: center; justify-content: center; gap: 16px;
      margin-bottom: 64px; flex-wrap: wrap;
    }
    .flow-node {
      padding: 10px 20px; border: 1px solid var(--line); border-radius: 8px;
      font-size: 13px; color: var(--heading); background: var(--bg2);
      text-align: center; min-width: 120px;
    }
    .flow-node.accent { border-color: var(--accent); background: rgba(139,124,248,0.08); }
    .flow-node.gold { border-color: var(--gold); background: rgba(230,168,23,0.06); color: var(--gold); }
    .flow-arrow { color: var(--muted); font-size: 18px; }

    /* ── Roadmap ── */
    .roadmap-section { padding: 120px 32px; max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }

    .roadmap-track { position: relative; padding-left: 40px; }
    .roadmap-track::before {
      content: ''; position: absolute; left: 12px; top: 0; bottom: 0;
      width: 1px; background: linear-gradient(to bottom, var(--accent), var(--gold), var(--muted));
    }

    .rm-item { position: relative; margin-bottom: 48px; }
    .rm-dot {
      position: absolute; left: -40px; top: 4px;
      width: 24px; height: 24px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; border: 2px solid var(--line);
      background: var(--bg);
    }
    .rm-dot.done { border-color: var(--jade); color: var(--jade); }
    .rm-dot.next { border-color: var(--accent); color: var(--accent); background: rgba(139,124,248,0.1); box-shadow: 0 0 12px var(--glow); }
    .rm-dot.future { border-color: var(--muted); color: var(--muted); }
    .rm-phase {
      font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 4px;
    }
    .rm-title { font-size: 18px; font-weight: 500; color: var(--heading); margin-bottom: 6px; }
    .rm-desc { font-size: 13px; color: var(--text); line-height: 1.6; }
    .rm-tag {
      display: inline-block; font-size: 9px; padding: 2px 8px; margin-top: 8px;
      border-radius: 3px; letter-spacing: 0.06em;
    }
    .rm-tag.done { color: var(--jade); background: rgba(34,197,94,0.1); }
    .rm-tag.next { color: var(--accent); background: rgba(139,124,248,0.1); }
    .rm-tag.future { color: var(--muted); background: rgba(85,85,112,0.15); }

    /* ── CTA ── */
    .vision-cta {
      text-align: center; padding: 120px 32px 80px;
      position: relative; z-index: 1;
    }
    .vision-cta h2 { font-size: 32px; font-weight: 300; color: var(--heading); margin-bottom: 16px; }
    .vision-cta p { color: var(--text); margin-bottom: 32px; }
    .vision-cta-links { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .vision-cta-links a {
      padding: 12px 28px; border-radius: 24px; font-size: 14px;
      text-decoration: none; transition: all 0.15s;
    }
    .btn-primary { background: var(--accent); color: #fff; border: 1px solid var(--accent); }
    .btn-primary:hover { background: var(--accent2); border-color: var(--accent2); color: var(--bg); }
    .btn-ghost { background: transparent; color: var(--text); border: 1px solid var(--line); }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Footer ── */
    .vision-footer {
      text-align: center; padding: 40px 32px; font-size: 11px; color: var(--muted);
      border-top: 1px solid var(--line); position: relative; z-index: 1;
    }
    .vision-footer a { color: var(--accent); text-decoration: none; }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(5px); }
    }

    .reveal {
      opacity: 0; transform: translateY(24px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-d1 { transition-delay: 0.1s; }
    .reveal-d2 { transition-delay: 0.2s; }
    .reveal-d3 { transition-delay: 0.3s; }

    /* ── Responsive ── */
    @media (max-width: 700px) {
      .dual-diagram { grid-template-columns: 1fr; }
      .dual-col-center { border-left: none; border-right: none; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
      .dual-flow { flex-direction: column; }
      .flow-arrow { transform: rotate(90deg); }
      .vision-nav { padding: 12px 20px; }
      .vision-nav-links { gap: 12px; }
    }
  </style>
</head>
<body>

<div class="vision-bg"></div>
<div class="grid-overlay"></div>

<!-- Nav -->
<header class="vision-nav">
  <a href="/" class="vision-nav-logo">
    <svg viewBox="0 0 32 32" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="16" cy="16" r="6.5" fill="url(#vg)"/>
      <ellipse cx="16" cy="16" rx="12" ry="4.5" stroke="#8b7cf8" stroke-width="1.5" transform="rotate(-22 16 16)" stroke-dasharray="20 18" stroke-dashoffset="-18"/>
      <defs><radialGradient id="vg" cx="40%" cy="35%" r="65%"><stop offset="0%" stop-color="#a89eff"/><stop offset="100%" stop-color="#6c5ce7"/></radialGradient></defs>
    </svg>
    Orbiter
  </a>
  <div class="vision-nav-links">
    <a href="/">Home</a>
    <a href="/docs/">Docs</a>
    <a href="https://github.com/aeon022/orbiter" class="btn-sm">GitHub</a>
  </div>
</header>

<!-- Hero -->
<section class="vision-hero">
  <div class="vision-eyebrow">Where we're going</div>
  <h1 class="vision-h1">One content source.<br /><em>Two audiences.</em></h1>
  <p class="vision-sub">The web is splitting into two layers: one for humans, one for AI agents. Orbiter is building for both — from a single POD.</p>
  <div class="vision-scroll-hint"><span>↓</span> Scroll to explore</div>
</section>

<!-- Dual Render -->
<section class="dual-section">
  <div class="dual-label reveal">The Dual Render Concept</div>
  <h2 class="dual-h2 reveal reveal-d1">Humans read stories.<br />Agents read structure.</h2>
  <p class="dual-body reveal reveal-d2">Today, websites serve one audience. Tomorrow, half your "visitors" will be AI agents — searching, comparing, summarizing. They don't need your CSS. They need your data. Dual Render serves both from the same DOM.</p>

  <div class="dual-diagram reveal reveal-d3">
    <div class="dual-col">
      <div class="dual-col-label">Human Layer</div>
      <div class="dual-col-icon">👁</div>
      <div class="dual-col-title">Visual & Narrative</div>
      <ul class="dual-col-items">
        <li>CSS layout & typography</li>
        <li>Images, video, animation</li>
        <li>Narrative flow & hierarchy</li>
        <li>Progressive disclosure</li>
      </ul>
    </div>
    <div class="dual-col dual-col-center">
      <div class="dual-col-label">Single Source</div>
      <div class="dual-col-icon">◈</div>
      <div class="dual-col-title">One POD</div>
      <ul class="dual-col-items">
        <li>Structured content</li>
        <li>Schema-aware fields</li>
        <li>Semantic depth tags</li>
        <li>One build, two outputs</li>
      </ul>
    </div>
    <div class="dual-col">
      <div class="dual-col-label">Agent Layer</div>
      <div class="dual-col-icon">⚡</div>
      <div class="dual-col-title">Structured & Semantic</div>
      <ul class="dual-col-items">
        <li><code>/llms.txt</code> content map</li>
        <li><code>/feed.json</code> structured API</li>
        <li>Semantic depth metadata</li>
        <li>RAG-ready format</li>
      </ul>
    </div>
  </div>

  <div class="dual-label reveal">The Stack</div>
  <div class="dual-flow reveal reveal-d1">
    <div class="flow-node accent">Orbiter POD</div>
    <span class="flow-arrow">→</span>
    <div class="flow-node">Astro Build</div>
    <span class="flow-arrow">→</span>
    <div class="flow-node gold">Dual Render</div>
  </div>

  <p class="dual-body reveal reveal-d2" style="text-align:center;max-width:700px;margin:0 auto;">
    Content lives in the POD. Astro builds the site. Dual Render splits the output — CSS-controlled visual layer for humans, structured semantic layer for AI agents. Same content, zero duplication.
  </p>
</section>

<!-- Roadmap -->
<section class="roadmap-section">
  <div class="dual-label reveal">Roadmap</div>
  <h2 class="dual-h2 reveal reveal-d1">What we've built.<br />Where we're going.</h2>

  <div class="roadmap-track" style="margin-top:48px;">

    <div class="rm-item reveal">
      <div class="rm-dot done">✓</div>
      <div class="rm-phase">Phase 01–12 · Complete</div>
      <div class="rm-title">Foundation → Launch Pad</div>
      <div class="rm-desc">Core DB, admin UI, block editor, media library, auth, themes, CLI, i18n, scheduled publishing, FTP deploy, desktop app, Station dock mode, file &amp; table fields, calendar view, cross-pod copy.</div>
      <span class="rm-tag done">19 features shipped</span>
    </div>

    <div class="rm-item reveal">
      <div class="rm-dot next">→</div>
      <div class="rm-phase">Next · In Progress</div>
      <div class="rm-title">Simple Analytics</div>
      <div class="rm-desc">Privacy-friendly page statistics stored directly in the POD. Pageviews, referrers, top pages — no Google Analytics, no external scripts. A &lt;1KB tracking snippet and a dashboard widget.</div>
      <span class="rm-tag next">~2 days</span>
    </div>

    <div class="rm-item reveal">
      <div class="rm-dot next">→</div>
      <div class="rm-phase">Next</div>
      <div class="rm-title">Form Builder UI</div>
      <div class="rm-desc">Visual form builder — drag fields, set validation, configure email templates. Generates the HTML snippet for your Astro page. The form inbox already exists; this completes the loop.</div>
      <span class="rm-tag next">~1-2 days</span>
    </div>

    <div class="rm-item reveal">
      <div class="rm-dot next">→</div>
      <div class="rm-phase">Next</div>
      <div class="rm-title">Multi-POD Dashboard</div>
      <div class="rm-desc">Manage multiple PODs from one desktop app window. Quick-switch between client sites, see entry counts and last-edit dates at a glance. Built for freelancers and agencies.</div>
      <span class="rm-tag next">~2 days</span>
    </div>

    <div class="rm-item reveal">
      <div class="rm-dot next">→</div>
      <div class="rm-phase">Next</div>
      <div class="rm-title">AI Content Assistant</div>
      <div class="rm-desc">Summarize, translate, generate SEO text, adjust tone — directly in the block editor via <code>/ai</code>. Supports Ollama (local, free) or OpenAI/Anthropic API keys. No cloud required.</div>
      <span class="rm-tag next">~2-3 days</span>
    </div>

    <div class="rm-item reveal">
      <div class="rm-dot future">◇</div>
      <div class="rm-phase">Future · Dual Render Integration</div>
      <div class="rm-title">llms.txt Auto-Generator</div>
      <div class="rm-desc">Orbiter automatically generates a structured content map at <code>/llms.txt</code> during every Astro build. AI agents get a curated entry point to your content — no manual maintenance.</div>
      <span class="rm-tag future">planned</span>
    </div>

    <div class="rm-item reveal">
      <div class="rm-dot future">◇</div>
      <div class="rm-phase">Future · Dual Render Integration</div>
      <div class="rm-title">Semantic Depth Fields</div>
      <div class="rm-desc">New field types and block-editor tags for semantic depth. Mark paragraphs as "surface" or "deep". The agent layer uses these markers to serve different levels of detail.</div>
      <span class="rm-tag future">planned</span>
    </div>

    <div class="rm-item reveal">
      <div class="rm-dot future">◇</div>
      <div class="rm-phase">Future · Dual Render Integration</div>
      <div class="rm-title">Agent Analytics</div>
      <div class="rm-desc">Distinguish human traffic from agent traffic in your analytics dashboard. See what percentage of your readers are AI systems. Understand how agents consume your content.</div>
      <span class="rm-tag future">planned</span>
    </div>

    <div class="rm-item reveal">
      <div class="rm-dot future">◇</div>
      <div class="rm-phase">Future</div>
      <div class="rm-title">SvelteKit Integration</div>
      <div class="rm-desc"><code>@a83/orbiter-sveltekit</code> — same virtual module API as the Astro integration, but as a Vite plugin for SvelteKit projects.</div>
      <span class="rm-tag future">planned</span>
    </div>

  </div>
</section>

<!-- CTA -->
<section class="vision-cta">
  <h2>Build for both worlds.</h2>
  <p>Start with Orbiter today — one file, no cloud, ready for the future.</p>
  <div class="vision-cta-links">
    <a href="https://github.com/aeon022/orbiter" class="btn-primary">View on GitHub →</a>
    <a href="/docs/quick-start" class="btn-ghost">Quick Start</a>
    <a href="https://a83tech.com" class="btn-ghost">Dual Render ↗</a>
  </div>
</section>

<footer class="vision-footer">
  🪐 Orbiter · MIT License · Built by <a href="https://abteilung83.at">Abteilung83</a>
</footer>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

</body>
</html>
