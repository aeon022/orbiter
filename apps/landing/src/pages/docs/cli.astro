    <tr><td><code>add-user</code></td><td><code>--username</code></td><td>Skip interactive prompt</td></tr>
    <tr><td><code>add-user</code></td><td><code>--role</code></td><td><code>admin</code> or <code>editor</code></td></tr>
    <tr><td><code>export</code></td><td><code>--pod</code></td><td>Path to the pod file</td></tr>
    <tr><td><code>export</code></td><td><code>--out</code></td><td>Output directory</td></tr>
    <tr><td><code>export</code></td><td><code>--format</code></td><td><code>json</code> (default) or <code>md</code></td></tr>
    <tr><td><code>export</code></td><td><code>--collection</code></td><td>Single collection to export</td></tr>
    <tr><td><code>unpack</code></td><td><code>--pod</code></td><td>Path to the pod file</td></tr>
    <tr><td><code>unpack</code></td><td><code>--out</code></td><td>Output directory for media files</td></tr>
    <tr><td><code>pack</code></td><td><code>--pod</code></td><td>Path to the pod file</td></tr>
