---
import '../styles/docs.css';
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
  prev?: { href: string; title: string };
  next?: { href: string; title: string };
  current?: string;
}

const { title, description, prev, next, current } = Astro.props;

const nav = [
  {
    label: 'Getting started',
    links: [
      { href: '/docs/',             title: 'Overview' },
      { href: '/docs/quick-start',  title: 'Quick start' },
    ],
  },
  {
    label: 'Content',
    links: [
      { href: '/docs/collections',    title: 'Collections & fields' },
      { href: '/docs/editor',         title: 'Editor' },
      { href: '/docs/trash',          title: 'Trash' },
      { href: '/docs/activity-log',   title: 'Activity log' },
      { href: '/docs/draft-preview',  title: 'Draft preview' },
      { href: '/docs/i18n',           title: 'Multilingual (i18n)' },
    ],
  },
  {
    label: 'Media',
    links: [
      { href: '/docs/media',        title: 'Media library' },
      { href: '/docs/media-backends', title: 'Media backends' },
    ],
  },
  {
    label: 'API & Integration',
    links: [
      { href: '/docs/collections-api', title: 'orbiter:collections' },
      { href: '/docs/typescript',   title: 'TypeScript' },
      { href: '/docs/json-api',     title: 'JSON API' },
    ],
  },
  {
    label: 'Deployment',
    links: [
      { href: '/docs/deployment',   title: 'Deployment' },
      { href: '/docs/git-sync',     title: 'Git sync mode' },
      { href: '/docs/build-webhook', title: 'Build webhook' },
    ],
  },
  {
    label: 'CLI',
    links: [
      { href: '/docs/cli',          title: 'CLI reference' },
    ],
  },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Orbiter Docs</title>
  {description && <meta name="description" content={description} />}
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <ViewTransitions />
</head>
<body>

  <header class="docs-header">
    <a class="docs-header-logo" href="/">
      <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="20" r="3" fill="currentColor" opacity=".9"/>
        <ellipse cx="20" cy="20" rx="17" ry="6" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".7" transform="rotate(-15 20 20)">
          <animateTransform attributeName="transform" type="rotate" from="-15 20 20" to="345 20 20" dur="4s" repeatCount="indefinite"/>
        </ellipse>
        <ellipse cx="20" cy="20" rx="17" ry="6" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".45" transform="rotate(75 20 20)">
          <animateTransform attributeName="transform" type="rotate" from="75 20 20" to="435 20 20" dur="6s" repeatCount="indefinite"/>
        </ellipse>
      </svg>
      Orbiter
    </a>
    <div class="docs-header-sep"></div>
    <span class="docs-header-label">Docs</span>
    <nav class="docs-header-links">
      <a href="/">Home</a>
      <a href="https://github.com/aeon022/orbiter" class="btn-gh" target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.185 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.2 22 16.447 22 12.021 22 6.484 17.522 2 12 2z"/></svg>
        <span>GitHub</span>
      </a>
    </nav>
  </header>

  <div class="docs-layout">
    <aside class="docs-sidebar">
      {nav.map(section => (
        <div class="nav-section">
          <div class="nav-section-label">{section.label}</div>
          {section.links.map(link => (
            <a
              href={link.href}
              class={`nav-link${current === link.href ? ' active' : ''}`}
            >
              {link.title}
            </a>
          ))}
        </div>
      ))}
    </aside>

    <main class="docs-main">
      <article class="prose">
        <slot />
      </article>

      {(prev || next) && (
        <nav class="docs-page-nav">
          {prev && (
            <a href={prev.href}>
              <span class="nav-dir">← Previous</span>
              <span class="nav-title">{prev.title}</span>
            </a>
          )}
          {next && (
            <a href={next.href} class="next">
              <span class="nav-dir">Next →</span>
              <span class="nav-title">{next.title}</span>
            </a>
          )}
        </nav>
      )}
    </main>
  </div>

</body>
</html>
